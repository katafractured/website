---
/**
 * Shared site layout — head, nav, footer, analytics.
 *
 * Every marketing page on katafract.com should use this layout so
 * the nav, footer, meta tags, and the Plausible first-party proxy
 * tag exist in exactly one place.
 */
import SiteNav from '../components/SiteNav.astro';
import SiteFooter from '../components/SiteFooter.astro';

export interface Props {
  title: string;
  description: string;
  canonical?: string;
  ogTitle?: string;
  ogDescription?: string;
  ogImage?: string;
  twitterCard?: 'summary' | 'summary_large_image';
  section?: 'home' | 'enclave' | 'dns' | 'platform' | 'apps' | 'pricing' | 'about' | 'prose' | 'welcome';
  noindex?: boolean;
}

const {
  title,
  description,
  canonical,
  ogTitle = title,
  ogDescription = description,
  ogImage = 'https://katafract.com/images/og-home.jpg',
  twitterCard = 'summary_large_image',
  section = 'home',
  noindex = false,
} = Astro.props;

const canonicalUrl = canonical ?? new URL(Astro.url.pathname, Astro.site).toString();
---
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title}</title>
  <meta name="description" content={description} />
  <link rel="canonical" href={canonicalUrl} />
  {noindex && <meta name="robots" content="noindex" />}

  <!-- Open Graph -->
  <meta property="og:title" content={ogTitle} />
  <meta property="og:description" content={ogDescription} />
  <meta property="og:url" content={canonicalUrl} />
  <meta property="og:type" content="website" />
  <meta property="og:site_name" content="Katafract" />
  <meta property="og:image" content={ogImage} />
  <meta property="og:image:width" content="1200" />
  <meta property="og:image:height" content="630" />

  <!-- Twitter -->
  <meta name="twitter:card" content={twitterCard} />
  <meta name="twitter:title" content={ogTitle} />
  <meta name="twitter:description" content={ogDescription} />
  <meta name="twitter:image" content={ogImage} />

  <!-- Favicon + fonts -->
  <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
  <link rel="preload" href="/fonts/cormorant-garamond-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="preload" href="/fonts/dm-sans-400.woff2" as="font" type="font/woff2" crossorigin />
  <link rel="stylesheet" href="/fonts.css" />

  <!-- Design system stylesheets -->
  <link rel="stylesheet" href="/styles/buttons.css" />
  <link rel="stylesheet" href="/styles/app-colors.css" />

  <!-- Page-specific head additions (JSON-LD, extra meta, inline styles) -->
  <slot name="head" />

  <!-- Privacy-friendly analytics, self-hosted on artemis. No cookies, no PII, no cross-site tracking.
       Variants: pageview-props (segmentation), tagged-events (CTA tracking), outbound-links (external
       clicks), revenue (amount tracking on tagged events). Served first-party via CF Pages Function
       proxy → pulse.katafract.io so ad-blockers can't strip it without breaking the host site. -->
  <script defer data-domain="katafract.com" data-api="/stats/api/event" src="/stats/js/script.pageview-props.tagged-events.outbound-links.revenue.js"></script>
  <!-- Manual-event helper: window.plausible('Event Name', {props:{...}, revenue:{amount,currency}}) -->
  <script>
    window.plausible = window.plausible || function(){(window.plausible.q = window.plausible.q || []).push(arguments)};

    // Scroll-depth tracking: fires once per pageload at 50% and 90%
    let scrollFired50 = false, scrollFired90 = false;
    window.addEventListener('scroll', () => {
      if (typeof window.plausible !== 'function') return;
      const scrollPercent = (window.scrollY + window.innerHeight) / document.documentElement.scrollHeight;
      if (scrollPercent >= 0.5 && !scrollFired50) {
        scrollFired50 = true;
        window.plausible('Scroll+50');
      }
      if (scrollPercent >= 0.9 && !scrollFired90) {
        scrollFired90 = true;
        window.plausible('Scroll+90');
      }
    }, { passive: true });
  </script>
</head>
<body>
  <SiteNav section={section} />
  <slot />
  <SiteFooter />
  <slot name="scripts" />
</body>
</html>
