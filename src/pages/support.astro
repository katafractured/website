---
import Base from '../layouts/Base.astro';
---
<Base
  title="Support — Katafract"
  description="Get help with Katafract apps. Select your app for FAQs, how-to guides, and contact information."
  ogDescription="Get help with Katafract apps. Select your app for FAQs and contact information."
  section="prose"
>
  <link slot="head" rel="stylesheet" href="/style.css" />
  <style slot="head" is:global>

    .app-support-list { display: flex; flex-direction: column; gap: 1rem; margin: 2rem 0 3rem; }
    .app-support-card {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      padding: 1.5rem;
      border-radius: 1rem;
      border: 1px solid rgba(100,100,120,0.14);
      background: rgba(10,10,20,0.4);
      text-decoration: none;
      transition: border-color 0.2s, background 0.2s;
    }
    .app-support-card:hover { text-decoration: none; background: rgba(10,10,20,0.7); }
    .app-support-icon {
      width: 52px; height: 52px; border-radius: 0.875rem;
      display: flex; align-items: center; justify-content: center;
      font-size: 1.4rem; flex-shrink: 0; border: 1px solid;
    }
    .app-support-meta { flex: 1; min-width: 0; }
    .app-support-name { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 700; color: #EBF0F7; margin-bottom: 0.2rem; }
    .app-support-desc { font-size: 0.875rem; color: #8C94A6; line-height: 1.5; }
    .app-support-status { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; padding: 0.2rem 0.6rem; border-radius: 999px; flex-shrink: 0; white-space: nowrap; }
    .app-support-arrow { color: #4a5060; font-size: 1.1rem; flex-shrink: 0; }
  
  </style>


    <div class="prose-header">
      <p class="prose-eyebrow">Katafract</p>
      <h1>Support</h1>
      <p class="prose-meta">Select your app below &mdash; or email <a href="mailto:hello@katafract.com">hello@katafract.com</a></p>
    </div>

    <div class="prose-body">

      <h2>Support by App</h2>
      <p>Choose your app to find FAQs, how-to guides, and troubleshooting help.</p>

      <div class="app-support-list">

        <a href="/support/exifarmor" class="app-support-card" style="border-color:rgba(0,240,255,0.1);" onmouseover="this.style.borderColor='rgba(0,240,255,0.25)'" onmouseout="this.style.borderColor='rgba(0,240,255,0.1)'">
          <div class="app-support-icon" style="background:rgba(0,240,255,0.05);border-color:rgba(0,240,255,0.2);color:#00F0FF">&#x1F6E1;&#xFE0F;</div>
          <div class="app-support-meta">
            <div class="app-support-name">ExifArmor</div>
            <div class="app-support-desc">Strip GPS and EXIF metadata from photos. Getting started, Pro features, troubleshooting.</div>
          </div>
          <span class="app-support-status" style="background:rgba(0,240,255,0.1);color:#00F0FF">Live on App Store</span>
          <span class="app-support-arrow">&#8250;</span>
        </a>

        <a href="/support/parkarmor" class="app-support-card" style="border-color:rgba(74,222,128,0.1);" onmouseover="this.style.borderColor='rgba(74,222,128,0.25)'" onmouseout="this.style.borderColor='rgba(74,222,128,0.1)'">
          <div class="app-support-icon" style="background:rgba(74,222,128,0.05);border-color:rgba(74,222,128,0.2);color:#4ADE80">&#x1F4CD;</div>
          <div class="app-support-meta">
            <div class="app-support-name">ParkArmor</div>
            <div class="app-support-desc">Save your parking spot, navigate back, set timers. Location, widgets, troubleshooting.</div>
          </div>
          <span class="app-support-status" style="background:rgba(74,222,128,0.1);color:#4ADE80">Up Next</span>
          <span class="app-support-arrow">&#8250;</span>
        </a>

        <a href="/support/docarmor" class="app-support-card" style="border-color:rgba(232,121,249,0.1);" onmouseover="this.style.borderColor='rgba(232,121,249,0.25)'" onmouseout="this.style.borderColor='rgba(232,121,249,0.1)'">
          <div class="app-support-icon" style="background:rgba(232,121,249,0.05);border-color:rgba(232,121,249,0.2);color:#E879F9">&#x1F510;</div>
          <div class="app-support-meta">
            <div class="app-support-name">DocArmor</div>
            <div class="app-support-desc">Encrypted document vault. Scanner, Face ID, security, troubleshooting.</div>
          </div>
          <span class="app-support-status" style="background:rgba(100,100,120,0.1);color:#8C94A6">Planned</span>
          <span class="app-support-arrow">&#8250;</span>
        </a>

      </div>

      <h2>Contact Us Directly</h2>
      <p>Didn&rsquo;t find what you were looking for? We&rsquo;re happy to help with any app.</p>
      <div class="contact-card">
        <h3>Get in Touch</h3>
        <p>Katafract LLC</p>
        <p><a href="mailto:hello@katafract.com">hello@katafract.com</a></p>
        <p>We typically respond within one business day.</p>
      </div>

    </div>
  
</Base>
