---
import Base from '../layouts/Base.astro';
---
<Base
  title={`Pricing — Katafract Enclave`}
  description={`Haven DNS free. Enclave VPN from $8/month. Sovereign with Vaultyx from $18/month. No identity required. Token-based. Cancel anytime.`}
  section="pricing"
>
  <link slot="head" rel="stylesheet" href="/style.css" />
  <style slot="head" is:global set:html={`
    .pricing-hero { padding: 8rem 0 4rem; text-align: center; }
    .pricing-hero h1 { font-family: 'Cormorant Garamond', serif; font-size: clamp(2.5rem,6vw,4rem); font-weight: 700; margin-bottom: 1rem; line-height: 1.1; }
    .pricing-hero p { color: #8C94A6; font-size: 1.1rem; max-width: 560px; margin: 0 auto 2.5rem; line-height: 1.7; }
    .toggle-row { display: flex; align-items: center; justify-content: center; gap: 1rem; margin-bottom: 4rem; font-size: .9rem; }
    .toggle-pill { background: #0a0a14; border: 1px solid rgba(100,100,120,.2); border-radius: 999px; padding: .2rem; display: flex; }
    .toggle-btn { padding: .4rem 1.25rem; border-radius: 999px; cursor: pointer; font-family: 'JetBrains Mono', monospace; font-size: .75rem; letter-spacing: .05em; border: none; background: transparent; color: #8C94A6; transition: all .2s; }
    .toggle-btn.active { background: rgba(255,0,110,.15); color: #FF006E; }
    .save-badge { font-family: 'JetBrains Mono', monospace; font-size: .65rem; padding: .2rem .6rem; border-radius: 999px; background: rgba(74,222,128,.15); color: #4ADE80; }
    .plans-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); gap: 1.5rem; max-width: 900px; margin: 0 auto 5rem; }
    .plan-card { background: #0a0a14; border: 1px solid rgba(100,100,120,.15); border-radius: 20px; padding: 2.5rem; position: relative; overflow: hidden; }
    .plan-card.featured { border-color: rgba(255,0,110,.3); }
    .plan-card.featured::before { content: ''; position: absolute; top: 0; left: 0; right: 0; height: 2px; background: linear-gradient(90deg, #FF006E, rgba(255,0,110,.2)); }
    .plan-label { font-family: 'JetBrains Mono', monospace; font-size: .65rem; letter-spacing: .25em; text-transform: uppercase; margin-bottom: 1.25rem; }
    .plan-name { font-family: 'Cormorant Garamond', serif; font-size: 2rem; font-weight: 700; margin-bottom: .5rem; }
    .plan-tagline { color: #8C94A6; font-size: .9rem; margin-bottom: 2rem; line-height: 1.5; }
    .plan-price { margin-bottom: 2rem; }
    .plan-price .amount { font-family: 'JetBrains Mono', monospace; font-size: 2.5rem; font-weight: 600; }
    .plan-price .period { color: #8C94A6; font-size: .85rem; }
    .plan-price .annual-note { font-family: 'JetBrains Mono', monospace; font-size: .7rem; color: #4ADE80; margin-top: .25rem; display: none; }
    .annual .plan-price .annual-note { display: block; }
    .plan-features { list-style: none; margin-bottom: 2rem; display: flex; flex-direction: column; gap: .75rem; }
    .plan-features li { display: flex; align-items: flex-start; gap: .6rem; font-size: .875rem; color: #8C94A6; }
    .plan-features li .check { flex-shrink: 0; margin-top: 1px; }
    .plan-features li.dim { opacity: .4; }
    .plan-cta { display: block; width: 100%; padding: .85rem; border-radius: 10px; text-align: center; font-family: 'JetBrains Mono', monospace; font-size: .875rem; font-weight: 500; cursor: pointer; text-decoration: none; transition: opacity .2s; }
    .plan-cta:hover { opacity: .85; text-decoration: none; }
    .plan-cta.primary { background: linear-gradient(135deg, rgba(255,0,110,.8), rgba(255,0,110,.5)); color: #fff; border: 1px solid rgba(255,0,110,.4); }
    .plan-cta.secondary { background: transparent; color: #4ADE80; border: 1px solid rgba(74,222,128,.3); }
    .plan-cta.ghost { background: transparent; color: #8C94A6; border: 1px solid rgba(100,100,120,.2); }
    .compare-table { max-width: 860px; margin: 0 auto 6rem; }
    .compare-table h2 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; text-align: center; margin-bottom: 2rem; }
    table { width: 100%; border-collapse: collapse; font-size: .875rem; }
    th { font-family: 'JetBrains Mono', monospace; font-size: .7rem; letter-spacing: .1em; text-transform: uppercase; color: #8C94A6; padding: .75rem 1rem; text-align: left; border-bottom: 1px solid rgba(100,100,120,.12); }
    th:not(:first-child) { text-align: center; }
    td { padding: .75rem 1rem; color: #8C94A6; border-bottom: 1px solid rgba(100,100,120,.06); }
    td:not(:first-child) { text-align: center; }
    td.yes { color: #4ADE80; }
    td.yes-mag { color: #FF006E; }
    td.no { color: #4a5060; }
    tr:hover td { background: rgba(100,100,120,.03); }
    .faq { max-width: 680px; margin: 0 auto 6rem; }
    .faq h2 { font-family: 'Cormorant Garamond', serif; font-size: 2rem; text-align: center; margin-bottom: 2.5rem; }
    .faq-item { border-bottom: 1px solid rgba(100,100,120,.1); padding: 1.25rem 0; cursor: pointer; }
    .faq-q { font-weight: 600; font-size: .95rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; }
    .faq-q::after { content: '+'; color: #8C94A6; font-size: 1.2rem; flex-shrink: 0; transition: transform .2s; }
    .faq-item.open .faq-q::after { transform: rotate(45deg); }
    .faq-a { color: #8C94A6; font-size: .9rem; line-height: 1.7; max-height: 0; overflow: hidden; transition: max-height .3s ease, padding .3s ease; }
    .faq-item.open .faq-a { max-height: 300px; padding-top: .75rem; }
    .dns-free-box { background: #0a0a14; border: 1px solid rgba(100,100,120,.15); border-radius: 16px; padding: 2.5rem; max-width: 700px; margin: 0 auto 6rem; text-align: center; }
    .dns-free-box h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.75rem; margin-bottom: .75rem; }
    .dns-free-box p { color: #8C94A6; font-size: .9rem; margin-bottom: 1.75rem; line-height: 1.7; }
    .dns-setup-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(140px, 1fr)); gap: 1rem; text-align: left; margin-bottom: 1.5rem; }
    .dns-setup-item { background: rgba(100,100,120,.05); border-radius: 8px; padding: .75rem; }
    .dns-setup-item .os { font-family: 'JetBrains Mono', monospace; font-size: .65rem; color: #8C94A6; letter-spacing: .1em; margin-bottom: .35rem; }
    .dns-setup-item .addr { font-family: 'JetBrains Mono', monospace; font-size: .75rem; color: #00F0FF; }
    @media (max-width: 640px) { .plans-grid { grid-template-columns: 1fr; } th, td { padding: .6rem .5rem; } }
  `}></style>
  <script slot="head" type="application/ld+json" is:inline set:html={`
[
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Haven",
    "description": "Encrypted DNS with ad, tracker, and malware blocking. No account, no payment, no logs.",
    "brand": {
      "@type": "Brand",
      "name": "Katafract"
    },
    "url": "https://katafract.com/dns",
    "offers": [
      {
