    },
    "url": "https://katafract.com/pricing",
    "offers": [
      {
        "@type": "Offer",
        "priceCurrency": "USD",
        "price": "8.00",
        "url": "https://buy.stripe.com/28E3cv0tH2qK5EK4kUffy0j",
        "billingDuration": "P1M",
        "pricingPattern": "Subscription"
      },
      {
        "@type": "Offer",
        "priceCurrency": "USD",
        "price": "64.00",
        "url": "https://buy.stripe.com/aFaaEXgsFghA8QWcRqffy0k",
        "billingDuration": "P1Y",
        "pricingPattern": "Subscription"
      }
    ]
  },
  {
    "@context": "https://schema.org",
    "@type": "Product",
    "name": "Sovereign",
    "description": "Complete privacy perimeter with multi-hop VPN, 1TB encrypted storage, and all apps included.",
    "brand": {
      "@type": "Brand",
      "name": "Katafract"
    },
    "url": "https://katafract.com/pricing",
    "offers": [
      {
        "@type": "Offer",
        "priceCurrency": "USD",
        "price": "18.00",
        "url": "https://buy.stripe.com/7sY9ATekx1mG2sydVuffy0h",
        "billingDuration": "P1M",
        "pricingPattern": "Subscription"
      },
      {
        "@type": "Offer",
        "priceCurrency": "USD",
        "price": "144.00",
        "url": "https://buy.stripe.com/8x228ra4h1mGaZ4dVuffy0i",
        "billingDuration": "P1Y",
        "pricingPattern": "Subscription"
      }
    ]
  }
]
  `}></script>
  <Fragment set:html={`<main>
<div class="container">

  <!-- Hero -->
  <div class="pricing-hero">
    <div class="section-label-sm fm" style="font-size:.65rem;color:#FF006E;letter-spacing:.3em;text-transform:uppercase;margin-bottom:1rem">Enclave Platform</div>
    <h1>Simple, honest pricing</h1>
    <p>Every paid Katafract app is unlocked with Enclave ($8/mo) — far cheaper than buying them separately. Infrastructure costs a subscription. Device-side tools are one-time. No surprises.</p>

    <div class="toggle-row">
      <span style="color:#8C94A6;font-size:.85rem">Monthly</span>
      <div class="toggle-pill">
        <button class="toggle-btn active" id="btn-monthly" onclick="setBilling('monthly')">Monthly</button>
        <button class="toggle-btn" id="btn-annual" onclick="setBilling('annual')">Annual</button>
      </div>
      <span class="save-badge" id="save-badge">Save 37%</span>
    </div>
  </div>

  <!-- Plans -->
  <div class="plans-grid" id="plans-grid">

    <!-- Apps (one-time) -->
    <div class="plan-card">
      <div class="plan-label" style="color:#00F0FF">Standalone</div>
      <div class="plan-name">Armor Apps</div>
      <div class="plan-tagline">Device-side privacy tools. Free to try, $0.99–$7.99 one-time, or included with Enclave.</div>
      <div class="plan-price">
        <div class="amount" style="color:#00F0FF">from $0.99</div>
        <div class="period">one-time per app</div>
      </div>
      <ul class="plan-features">
        <li><span class="check" style="color:#00F0FF">✓</span> ExifArmor — strip photo metadata · $0.99</li>
        <li><span class="check" style="color:#00F0FF">✓</span> ParkArmor — parking spot saver · $0.99</li>
        <li><span class="check" style="color:#00F0FF">✓</span> DocArmor — encrypted vault · $7.99</li>
        <li><span class="check" style="color:#00F0FF">✓</span> SafeOpen — link inspector · Free + credits</li>
        <li><span class="check" style="color:#00F0FF">✓</span> No cloud, no account, no tracking</li>
        <li class="dim"><span class="check">–</span> Network protection</li>
        <li class="dim"><span class="check">–</span> VPN routing</li>
      </ul>
      <a href="/#apps" class="plan-cta secondary">See All Apps →</a>
    </div>

    <!-- Haven (free) -->
    <div class="plan-card">
      <div class="plan-label" style="color:#4ADE80">Haven · Always Free</div>
      <div class="plan-name">Haven</div>
      <div class="plan-tagline">Encrypted DNS with ad, tracker, and malware blocking. No account, no payment, no logs.</div>
      <div class="plan-price">
        <div class="amount" style="color:#4ADE80">Free</div>
        <div class="period">forever, included with any tier</div>
      </div>
      <ul class="plan-features">
        <li><span class="check" style="color:#4ADE80">✓</span> Encrypted DNS (DoH + DoT)</li>
        <li><span class="check" style="color:#4ADE80">✓</span> Ad + tracker blocking</li>
        <li><span class="check" style="color:#4ADE80">✓</span> Malware + phishing domains blocked</li>
        <li><span class="check" style="color:#4ADE80">✓</span> Works on all devices</li>
        <li><span class="check" style="color:#4ADE80">✓</span> No logs · No account needed</li>
        <li class="dim"><span class="check">–</span> VPN routing</li>
        <li class="dim"><span class="check">–</span> Advanced DNS tiers</li>
      </ul>
      <a href="/dns" class="plan-cta secondary" id="cta-haven">Setup Haven →</a>
    </div>

    <!-- Enclave VPN (2-tier) -->
    <div class="plan-card featured">
      <div style="position:absolute;top:0;right:0;width:200px;height:200px;background:radial-gradient(circle,rgba(255,0,110,.08) 0%,transparent 70%);pointer-events:none"></div>
      <div class="plan-label" style="color:#FF006E">Enclave · Most Popular</div>
      <div class="plan-name">Enclave</div>
      <div class="plan-tagline">Single-hop WireGuard VPN, all utility apps unlocked, 50 AI credits/month, DNS tier picker.</div>
      <div class="plan-price">
        <div class="amount monthly-price" style="color:#FF006E">$8</div>
        <div class="amount annual-price" style="color:#FF006E;display:none">$5.33</div>
        <div class="period">/ month</div>
        <div class="annual-note">billed $64/year — save 33%</div>
      </div>
      <ul class="plan-features">
        <li><span class="check" style="color:#FF006E">✓</span> VPN — global nodes (EU, US, Asia)</li>
        <li><span class="check" style="color:#FF006E">✓</span> Haven DNS (Low/Standard/High/Family)</li>
        <li><span class="check" style="color:#FF006E">✓</span> ExifArmor, ParkArmor, DocArmor, SafeOpen unlocked</li>
        <li><span class="check" style="color:#FF006E">✓</span> 50 AI credits/month (MeritMosaic, SafeOpen, future features)</li>
        <li><span class="check" style="color:#FF006E">✓</span> Connect on 5 devices</li>
        <li><span class="check" style="color:#FF006E">✓</span> No logs · No identity stored</li>
      </ul>
      <a href="https://buy.stripe.com/bJe28r4JX9TcgjocRqffy04" class="plan-cta primary plausible-event-name=Subscribe+Click" id="cta-enclave">Get Enclave →</a>
    </div>

    <!-- Add-ons -->
    <div class="plan-card" style="background:#0a0a14;border:1px solid rgba(100,100,120,.1)">
      <div class="plan-label" style="color:#FFB700">Add-ons</div>
      <div class="plan-name">Enhance Your Plan</div>
      <div class="plan-tagline">Transparent cost-plus pricing on actual infrastructure costs.</div>
      <div class="plan-price" style="margin-bottom:1.5rem">
        <div class="amount" style="color:#FFB700;font-size:1.5rem">Flexible</div>
        <div class="period">by usage or fixed tier</div>
      </div>
      <ul class="plan-features">
        <li><span class="check" style="color:#FFB700">⚙</span> Storage beyond 1TB: <strong>+$4/mo per TB</strong></li>
        <li><span class="check" style="color:#FFB700">⚙</span> AI credits top-up: <strong>$5 = 100 credits</strong> (never expire)</li>
        <li><span class="check" style="color:#FFB700">⚙</span> Multi-hop routing: <strong>included in Sovereign</strong></li>
        <li><span class="check" style="color:#FFB700">⚙</span> Unlimited devices: <strong>Sovereign only</strong></li>
        <li class="dim"><span class="check">–</span> No hidden charges</li>
        <li class="dim"><span class="check">–</span> All prices in USD</li>
      </ul>
      <a href="mailto:hello@katafract.com" class="plan-cta ghost">Questions? Email us →</a>
    </div>

    <!-- Sovereign -->
    <div class="plan-card featured">
      <div style="position:absolute;top:0;right:0;width:200px;height:200px;background:radial-gradient(circle,rgba(255,0,110,.08) 0%,transparent 70%);pointer-events:none"></div>
      <div class="plan-label" style="color:#FF006E">Sovereign · Complete</div>
      <div class="plan-name">Sovereign</div>
      <div class="plan-tagline">Own your data infrastructure. Multi-hop VPN, 1TB encrypted cloud storage, all apps included.</div>
      <div class="plan-price">
        <div class="amount monthly-price" style="color:#FF006E">$18</div>
        <div class="amount annual-price" style="color:#FF006E;display:none">$12</div>
        <div class="period">/ month</div>
        <div class="annual-note">billed $144/year — save 33%</div>
      </div>
      <ul class="plan-features">
        <li><span class="check" style="color:#FF006E">✓</span> Everything in Enclave</li>
        <li><span class="check" style="color:#FF006E">✓</span> Multi-hop VPN routing (double encapsulation)</li>
        <li><span class="check" style="color:#FF006E">✓</span> Vaultyx — 1TB encrypted storage with FastCDC delta sync</li>
        <li><span class="check" style="color:#FF006E">✓</span> DocArmor cloud backup included</li>
        <li><span class="check" style="color:#FF006E">✓</span> Praetor (when shipping) + all future apps</li>
        <li><span class="check" style="color:#FF006E">✓</span> Unlimited devices · Cross-device sync</li>
      </ul>
      <a href="https://buy.stripe.com/7sY9ATekx1mG2sydVuffy0h"  class="plan-cta primary plausible-event-name=Subscribe+Click" id="cta-sovereign">Get Sovereign →</a>
    </div>

  </div>

  <!-- Free Haven DNS -->
  <div class="dns-free-box">
    <h2>Haven DNS — always free, no account</h2>
    <p>Basic DNS protection — ad blocking, tracker blocking — is available without a subscription. Just point your DNS to our servers. Nothing to install, no sign-up.</p>
    <div class="dns-setup-grid">
      <div class="dns-setup-item"><div class="os">iPhone</div><div class="addr">dns.katafract.com</div></div>
      <div class="dns-setup-item"><div class="os">Android</div><div class="addr">dns.katafract.com</div></div>
      <div class="dns-setup-item"><div class="os">macOS</div><div class="addr">dns.katafract.com</div></div>
      <div class="dns-setup-item"><div class="os">Router</div><div class="addr">dns.katafract.com</div></div>
    </div>
    <a href="/dns" style="font-family:'JetBrains Mono',monospace;font-size:.8rem;color:#4ADE80">Setup guide →</a>
  </div>

  <!-- Vaultyx comparison -->
  <div class="compare-table">
    <h2>Vaultyx vs Competitors</h2>
    <p style="text-align:center;color:#8C94A6;font-size:.9rem;margin-bottom:2rem;">Sovereign includes Vaultyx with 1TB storage, plus VPN, DNS, and DocArmor cloud backup</p>
    <table>
      <thead>
        <tr>
          <th>Feature</th>
          <th style="color:#FF006E">Vaultyx</th>
          <th style="color:#8C94A6">iCloud+</th>
          <th style="color:#8C94A6">Dropbox</th>
          <th style="color:#8C94A6">Google One</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Client-side encryption</td><td class="yes-mag">AES-256-GCM</td><td class="no">Server-side only</td><td class="no">Server-side only</td><td class="no">Server-side only</td></tr>
        <tr><td>Can provider read files?</td><td class="yes-mag">Never — we have no keys</td><td class="no">Yes, Apple can</td><td class="no">Yes, Dropbox can</td><td class="no">Yes, Google can</td></tr>
        <tr><td>Content scanning (CSAM/AI)</td><td class="yes-mag">None</td><td class="no">CSAM scanning on upload</td><td class="no">Malware scanning</td><td class="no">AI training on content</td></tr>
        <tr><td>Delta sync (FastCDC)</td><td class="yes-mag">Only changed chunks</td><td class="no">Full re-upload</td><td class="yes">Yes, but proprietary</td><td class="no">Full re-upload</td></tr>
        <tr><td>VPN routing integration</td><td class="yes-mag">Auto routes via WraithVPN</td><td class="no">None</td><td class="no">None</td><td class="no">None</td></tr>
        <tr><td>Lock-in risk</td><td class="yes-mag">Standard S3 export</td><td class="no">Proprietary format</td><td class="no">Proprietary format</td><td class="no">Proprietary format</td></tr>
        <tr><td>1TB monthly price</td><td class="yes-mag">$18 (inc. VPN+DNS+apps)</td><td class="no">$9.99</td><td class="no">$11.99</td><td class="no">$9.99</td></tr>
      </tbody>
    </table>
  </div>

  <!-- Feature comparison -->
  <div class="compare-table">
    <h2>Full comparison</h2>
    <table>
      <thead>
        <tr>
          <th>Feature</th>
          <th style="color:#00F0FF">Apps</th>
          <th style="color:#4ADE80">Haven</th>
          <th style="color:#FF006E">Enclave</th>
          <th style="color:#FFB700">Add-ons</th>
          <th style="color:#FF006E">Sovereign</th>
        </tr>
      </thead>
      <tbody>
        <tr><td>Ad + tracker blocking</td><td class="no">—</td><td class="yes">✓</td><td class="yes-mag">✓</td><td class="yes-mag">✓</td><td class="yes-mag">✓</td></tr>
        <tr><td>Malware domain blocking</td><td class="no">—</td><td class="yes">✓</td><td class="yes-mag">✓</td><td class="yes-mag">✓</td><td class="yes-mag">✓</td></tr>
        <tr><td>Enclave VPN</td><td class="no">—</td><td class="no">—</td><td class="yes-mag">✓</td><td class="yes-mag">✓</td><td class="yes-mag">✓</td></tr>
        <tr><td>Global exit nodes</td><td class="no">—</td><td class="no">—</td><td class="yes-mag">EU, US, Asia</td><td class="yes-mag">EU, US, Asia</td><td class="yes-mag">EU, US, Asia</td></tr>
        <tr><td>Multi-hop routing (double encapsulation)</td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="yes-mag">✓</td></tr>
        <tr><td>Vaultyx encrypted storage</td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="yes-mag">1TB</td></tr>
        <tr><td>FastCDC delta sync</td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="yes-mag">✓</td></tr>
        <tr><td>Alias Guard <span style="font-size:.7rem;opacity:.5">(coming soon)</span></td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="no">—</td><td class="no">—</td></tr>
