---
import Base from '../../layouts/Base.astro';
---
<Base
  title={`ExifArmor — Share photos, not your location`}
  description={`ExifArmor strips hidden GPS and metadata from your photos before you share them. One tap. No cloud. Your photos never leave your device.`}
  section="apps"
  ogDescription={`Every photo you share contains hidden GPS coordinates, device info, and timestamps. ExifArmor strips it all with one tap. Free with 5 daily strips, or $0.99 to unlock.`}
  ogImage="https://katafract.com/images/og-exifarmor.jpg"
>
  <link slot="head" rel="stylesheet" href="/style.css" />
  <style slot="head" is:global set:html={`
    /* App page hero */
    .app-hero {
      padding: 4rem 1.5rem 3rem;
      max-width: 900px;
      margin: 0 auto;
    }
    .app-main { max-width: 900px; margin: 0 auto; padding: 0 1.5rem 5rem; }
    .app-hero-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--cyan);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .app-hero-eyebrow .back-link {
      color: var(--dim2);
      font-size: 0.65rem;
      letter-spacing: 0.15em;
    }
    .app-hero-eyebrow .back-link:hover { color: var(--dim); text-decoration: none; }
    .app-hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.8rem, 6vw, 4rem);
      font-weight: 700;
      line-height: 1.08;
      letter-spacing: -0.01em;
      margin-bottom: 1.25rem;
    }
    .app-hero h1 em { font-style: normal; color: var(--cyan); }
    .app-hero .tagline {
      font-size: 1.1rem;
      color: var(--dim);
      line-height: 1.7;
      max-width: 580px;
      margin-bottom: 2.5rem;
    }
    .app-cta-row {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-wrap: wrap;
      margin-bottom: 3rem;
    }
    .btn-appstore {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: white;
      color: #050510;
      font-weight: 700;
      font-size: 0.9rem;
      padding: 0.8rem 1.75rem;
      border-radius: 999px;
      transition: background 0.15s;
    }
    .btn-appstore:hover { background: #e8e8e8; text-decoration: none; }
    .price-note {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      color: var(--dim2);
    }

    /* Divider */
    .section-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 3.5rem 0;
    }

    /* Feature grid */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
      gap: 1rem;
      margin: 2rem 0 3rem;
    }
    .feature-card {
      background: rgba(10,10,20,0.5);
      border: 1px solid var(--border);
      border-radius: 1rem;
      padding: 1.5rem;
      transition: border-color 0.2s;
    }
    .feature-card:hover { border-color: rgba(0,240,255,0.18); }
    .feature-icon {
      font-size: 1.5rem;
      margin-bottom: 0.75rem;
    }
    .feature-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.4rem;
    }
    .feature-desc {
      font-size: 0.875rem;
      color: var(--dim);
      line-height: 1.65;
    }

    /* How it works */
    .steps {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin: 2rem 0 3rem;
    }
    .step {
      display: flex;
      gap: 1.25rem;
      align-items: flex-start;
    }
    .step-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--cyan);
      background: rgba(0,240,255,0.07);
      border: 1px solid rgba(0,240,255,0.15);
      border-radius: 50%;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .step-body h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.3rem;
    }
    .step-body p {
      font-size: 0.9rem;
      color: var(--dim);
      line-height: 1.65;
      margin: 0;
    }

    /* Privacy callout override */
    .privacy-block {
      background: rgba(0,240,255,0.03);
      border: 1px solid rgba(0,240,255,0.1);
      border-radius: 1rem;
      padding: 2rem;
      margin: 2rem 0;
    }
    .privacy-block h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.35rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.75rem;
    }
    .privacy-block p {
      font-size: 0.9rem;
      color: var(--dim);
      line-height: 1.7;
      margin-bottom: 0.5rem;
    }
    .privacy-block p:last-child { margin-bottom: 0; }
    .privacy-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1rem;
    }
    .privacy-pill {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      background: rgba(0,240,255,0.06);
      border: 1px solid rgba(0,240,255,0.12);
      color: #33E8A0;
    }

    /* Section headings inside prose-page override */
    .app-page-section {
      margin-bottom: 0.5rem;
    }
    .app-section-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      color: var(--cyan);
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }
    .app-section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.6rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.5rem;
    }
    .app-section-sub {
      font-size: 0.95rem;
      color: var(--dim);
      line-height: 1.7;
      margin-bottom: 0;
    }
    @media (min-width: 768px) {
      .app-hero { padding: 6rem 3.5rem 4.5rem; }
      .app-main { padding: 0 3.5rem 7rem; }
    }
    @media (min-width: 1100px) {
      .app-hero { padding: 7rem 5rem 5rem; }
      .app-main { padding: 0 5rem 8rem; }
    }
    @media (max-width: 480px) {
      .app-hero { padding: 3rem 1.25rem 2.5rem; }
      .app-main { padding: 0 1.25rem 4rem; }
    }
  `}></style>
  <script slot="head" type="application/ld+json" is:inline set:html={`
  {
    "@context": "https://schema.org",
    "@type": "SoftwareApplication",
    "name": "ExifArmor",
    "applicationCategory": "UtilitiesApplication",
    "operatingSystem": "iOS",
    "description": "Remove hidden metadata from photos — GPS, device, timestamp — with one tap. Your originals are never touched.",
    "offers": [
      { "@type": "Offer", "price": "0", "priceCurrency": "USD", "name": "Free" },
      { "@type": "Offer", "price": "0.99", "priceCurrency": "USD", "name": "Pro" }
    ],
    "url": "https://apps.apple.com/app/id6760979268",
    "downloadUrl": "https://apps.apple.com/app/id6760979268"
  }
  `}></script>
  <Fragment set:html={`<div class="app-hero">
    <div class="app-hero-eyebrow">
      <span>ExifArmor</span>
      <span>&middot;</span>
      <a href="/" class="back-link">by Katafract &nearr;</a>
    </div>
    <h1>Share photos,<br>not your <em>location</em></h1>
    <p class="tagline">Every photo you take contains hidden metadata &mdash; your GPS coordinates, device model, and exact timestamp. ExifArmor reveals what&rsquo;s embedded, then strips it with one tap. Your originals are never touched.</p>
    <div class="app-cta-row">
      <a href="https://apps.apple.com/app/id6760979268" class="btn-appstore">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 21.99 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09 21.99C7.79 22.03 6.8 20.68 5.96 19.47C4.25 16.97 2.94 12.45 4.7 9.39C5.57 7.87 7.13 6.91 8.82 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/></svg>
        Download on the App Store
      </a>
      <span class="price-note">Free · Pro $0.99 one-time · Or included with Enclave</span>
    </div>
  </div>

  <main class="app-main">

    <hr class="section-divider">

    <div class="app-page-section">
      <div class="app-section-label">Features</div>
      <h2 class="app-section-title">Everything you need, nothing you don&rsquo;t</h2>
      <p class="app-section-sub">Built for people who care about what they share.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">&#x1F5FA;&#xFE0F;</div>
        <div class="feature-title">Exposure Preview</div>
        <div class="feature-desc">See exactly what&rsquo;s hidden in your photo &mdash; GPS pin on a map, device model, timestamps &mdash; before you decide what to strip.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x26A1;</div>
        <div class="feature-title">One-Tap Strip</div>
        <div class="feature-desc">Remove all metadata from a photo in a single tap. A clean copy is saved to your library. Your original is untouched.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F4F8;</div>
        <div class="feature-title">Batch Mode</div>
        <div class="feature-desc">Select dozens of photos at once and strip them all in one go. Pro feature &mdash; perfect before bulk sharing or posting.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F517;</div>
        <div class="feature-title">Share Extension</div>
        <div class="feature-desc">Strip metadata directly from Photos, Messages, or any other app using the iOS share sheet. Never leave the app you&rsquo;re in.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F527;</div>
        <div class="feature-title">Custom Strip</div>
        <div class="feature-desc">Choose exactly which fields to remove and which to keep. Keep the timestamp but drop GPS. Your call, every time.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F6E1;&#xFE0F;</div>
        <div class="feature-title">Privacy Report</div>
        <div class="feature-desc">Track how many exposures you&rsquo;ve neutralized over time. Badges reward consistent privacy habits.</div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="app-page-section">
      <div class="app-section-label">How It Works</div>
      <h2 class="app-section-title">Three steps, one clean photo</h2>
    </div>

    <div class="steps">
      <div class="step">
        <div class="step-num">01</div>
        <div class="step-body">
          <h3>Select &amp; Preview</h3>
          <p>Pick any photo from your library. ExifArmor shows you exactly what metadata is embedded &mdash; GPS on a map, device info, timestamps. No surprises.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">02</div>
        <div class="step-body">
          <h3>Strip</h3>
          <p>Tap &ldquo;Strip &amp; Save.&rdquo; ExifArmor creates a clean copy with the selected metadata removed. The original stays in your library, unchanged.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">03</div>
        <div class="step-body">
          <h3>Share Safely</h3>
          <p>Share the clean copy however you like &mdash; Messages, Instagram, email, AirDrop. What people see is exactly what you chose to share.</p>
        </div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="privacy-block">
      <h2>&#x1F512; Your photos never leave your device</h2>
      <p>ExifArmor processes everything on-device. There are no servers, no cloud uploads, no network calls. Your photos, their metadata, and the cleaned versions stay entirely on your iPhone.</p>
      <p>Apple Privacy Nutrition Label: <strong>Data Not Collected.</strong></p>
      <div class="privacy-pills">
        <span class="privacy-pill">No data collected</span>
        <span class="privacy-pill">No accounts</span>
        <span class="privacy-pill">No analytics</span>
        <span class="privacy-pill">No network calls</span>
        <span class="privacy-pill">Originals untouched</span>
      </div>
    </div>

    <hr class="section-divider">

    <div class="callout">
      <p><strong>Free to download.</strong> Strip up to 5 photos per day at no cost &mdash; no account, no trial, no expiry. <strong>ExifArmor Pro ($0.99, one-time)</strong> unlocks unlimited strips, batch mode, the iOS share extension for stripping directly from Photos or any app, and custom strip options. A permanent license tied to your Apple ID, restorable on any device. Or subscribe to Enclave ($8/mo) to unlock this and 4 other Katafract apps. Refunds are handled by Apple at <a href="https://reportaproblem.apple.com" target="_blank" rel="noopener">reportaproblem.apple.com</a>.</p>
      <p style="margin-top:0.75rem;margin-bottom:0"><a href="/terms/exifarmor">Full Terms of Service &rarr;</a></p>
    </div>

    <hr class="section-divider">

    <div class="app-page-section" style="margin-bottom:1.5rem">
      <div class="app-section-label">Pricing</div>
      <h2 class="app-section-title">One price. Yours forever.</h2>
    </div>

    <div style="display:grid;grid-template-columns:1fr 1fr;gap:1rem;margin-bottom:2.5rem">
      <div style="background:rgba(10,10,20,0.5);border:1px solid var(--border);border-radius:1rem;padding:1.5rem">
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--dim2);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem">Free</div>
        <div style="font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:700;color:var(--text);margin-bottom:1rem">$0</div>
        <ul style="list-style:none;padding:0;margin:0;font-size:0.875rem;color:var(--dim);display:flex;flex-direction:column;gap:0.5rem">
          <li>&#x2713; 5 strips per day</li>
          <li>&#x2713; Exposure preview</li>
          <li>&#x2713; GPS map view</li>
        </ul>
      </div>
      <div style="background:rgba(0,240,255,0.04);border:1px solid rgba(0,240,255,0.18);border-radius:1rem;padding:1.5rem">
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--cyan);text-transform:uppercase;letter-spacing:0.1em;margin-bottom:0.5rem">Pro</div>
        <div style="font-family:'Cormorant Garamond',serif;font-size:2rem;font-weight:700;color:var(--text);margin-bottom:0.15rem">$0.99</div>
        <div style="font-family:'JetBrains Mono',monospace;font-size:0.65rem;color:var(--dim2);margin-bottom:1rem">one-time purchase</div>
        <ul style="list-style:none;padding:0;margin:0;font-size:0.875rem;color:var(--dim);display:flex;flex-direction:column;gap:0.5rem">
          <li style="color:var(--text)">&#x2713; Unlimited strips</li>
          <li style="color:var(--text)">&#x2713; Batch mode</li>
          <li style="color:var(--text)">&#x2713; Share extension</li>
          <li style="color:var(--text)">&#x2713; Custom strip options</li>
          <li>&#x2713; Everything in Free</li>
        </ul>
      </div>
    </div>

    <div style="text-align:center;margin-bottom:1rem">
      <a href="https://apps.apple.com/app/id6760979268" class="btn-appstore">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 21.99 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09 21.99C7.79 22.03 6.8 20.68 5.96 19.47C4.25 16.97 2.94 12.45 4.7 9.39C5.57 7.87 7.13 6.91 8.82 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/></svg>
        Download on the App Store
      </a>
    </div>
    <div style="text-align:center;font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:var(--dim2)">
      Requires iOS 17.0 or later &middot; iPhone
    </div>

  </main>`} />
</Base>
