---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
import { appBySlug } from '../../data/apps';
const app = appBySlug('safeopen');
---
<Base
  title="SafeOpen · Inspect any link before you tap it"
  description="Free QR scanner and link inspector for iOS. On-device risk scoring runs offline. Optional scan credits unlock AI summaries and a privacy relay for the links you actually want to open. No subscription."
  ogDescription="Free QR scanner and link inspector. Pay only for the AI summaries and privacy-relay opens you actually use. Credits never expire."
  section="apps"
  twitterCard="summary_large_image"
>
  <link slot="head" rel="stylesheet" href="/style.css" />

  <style slot="head" is:global>
    :root { --app-accent: var(--safeopen); }
    /* .app-main / .section-divider / .app-section-{label,title,sub} live in /style.css */
    .live-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      padding: 0.6rem 1.25rem;
      border-radius: 999px;
      background: rgba(0,212,255,0.08);
      border: 1px solid rgba(0,212,255,0.2);
      color: var(--app-accent);
      margin-bottom: 3rem;
    }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin: 2rem 0 3rem; }
    .feature-card { background: rgba(10,10,20,0.5); border: 1px solid var(--border); border-radius: 1rem; padding: 1.5rem; transition: border-color 0.2s; }
    .feature-card:hover { border-color: rgba(0,212,255,0.2); }
    .feature-icon { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--app-accent); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 0.85rem; opacity: 0.85; }
    .feature-title { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600; color: var(--text); margin-bottom: 0.4rem; }
    .feature-desc { font-size: 0.875rem; color: var(--dim); line-height: 1.65; }
    .pack-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin: 2rem 0 1.5rem; }
    .pack-card { background: rgba(10,10,20,0.5); border: 1px solid var(--border); border-radius: 1rem; padding: 1.75rem 1.5rem; text-align: center; }
    .pack-card.feature { border-color: rgba(0,212,255,0.35); background: rgba(0,212,255,0.03); }
    .pack-label { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--app-accent); letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 0.5rem; }
    .pack-credits { font-family: 'Cormorant Garamond', serif; font-size: 2.2rem; font-weight: 700; color: var(--text); line-height: 1; }
    .pack-credits-label { font-size: 0.78rem; color: var(--dim); margin-top: 0.15rem; }
    .pack-price { font-family: 'JetBrains Mono', monospace; font-size: 1.15rem; color: var(--app-accent); margin-top: 0.85rem; }
    .pack-per { font-size: 0.7rem; color: var(--dim2); margin-top: 0.2rem; font-family: 'JetBrains Mono', monospace; }
    .pack-best { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; color: var(--app-accent); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 0.5rem; }
    .steps { display: flex; flex-direction: column; gap: 1.5rem; margin: 2rem 0 3rem; }
    .step { display: flex; gap: 1.25rem; align-items: flex-start; }
    .step-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--app-accent);
      background: rgba(0,212,255,0.07);
      border: 1px solid rgba(0,212,255,0.15);
      border-radius: 50%;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .step-body h3 { font-family: 'Cormorant Garamond', serif; font-size: 1.15rem; font-weight: 600; color: var(--text); margin-bottom: 0.3rem; }
    .step-body p { font-size: 0.9rem; color: var(--dim); line-height: 1.65; margin: 0; }
    .privacy-block { background: rgba(0,212,255,0.03); border: 1px solid rgba(0,212,255,0.1); border-radius: 1rem; padding: 2rem; margin: 2rem 0; }
    .privacy-block h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.35rem; font-weight: 600; color: var(--text); margin-bottom: 0.75rem; }
    .privacy-block p { font-size: 0.9rem; color: var(--dim); line-height: 1.7; margin-bottom: 0.6rem; }
    .privacy-block p:last-child { margin-bottom: 0; }
    .privacy-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
    .privacy-pill { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; padding: 0.25rem 0.75rem; border-radius: 999px; background: rgba(0,212,255,0.06); border: 1px solid rgba(0,212,255,0.15); color: var(--app-accent); }

    .qr-demo-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(190px, 1fr)); gap: 1.25rem; margin: 2rem 0 1rem; }
    .qr-demo-card { background: rgba(10,10,20,0.5); border: 1px solid var(--border); border-radius: 1rem; padding: 1.5rem 1.25rem 1.25rem; display: flex; flex-direction: column; align-items: center; gap: 1rem; transition: border-color 0.2s; }
    .qr-demo-card:hover { border-color: rgba(255,255,255,0.12); }
    .qr-demo-card img { width: 130px; height: 130px; border-radius: 0.5rem; display: block; }
    .qr-demo-badge { font-family: 'JetBrains Mono', monospace; font-size: 0.6rem; letter-spacing: 0.2em; text-transform: uppercase; padding: 0.22rem 0.7rem; border-radius: 999px; }
    .qr-badge-safe    { background: rgba(52,211,153,0.1);  border: 1px solid rgba(52,211,153,0.3);  color: #34D399; }
    .qr-badge-neutral { background: rgba(148,163,184,0.1); border: 1px solid rgba(148,163,184,0.25); color: #94A3B8; }
    .qr-badge-medium  { background: rgba(251,191,36,0.1);  border: 1px solid rgba(251,191,36,0.3);  color: #FBBF24; }
    .qr-badge-high    { background: rgba(239,68,68,0.1);   border: 1px solid rgba(239,68,68,0.3);   color: #EF4444; }
    .qr-demo-dest { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--dim); word-break: break-all; text-align: center; }
    .qr-demo-result { font-size: 0.8rem; color: var(--dim); line-height: 1.5; text-align: center; }
  </style>

  <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "SafeOpen",
      "operatingSystem": "iOS",
      "applicationCategory": "SecurityApplication",
      "description": "Know what you're opening. QR codes and short links can lead anywhere. SafeOpen follows the full redirect chain and shows you the destination before you open it.",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "USD",
        "price": "0",
        "description": "Free + per-scan credits from $0.99"
      },
      "author": {
        "@type": "Organization",
        "name": "Katafract LLC"
      }
    }
  </script>

  <PageHero
    eyebrow={app?.name}
    title="Know before you <em>open.</em>"
    subhead="A free QR scanner and link inspector for iOS. Risk scoring runs entirely on your device. Optional scan credits unlock AI summaries and a privacy relay for the links you actually want to open."
    accent="var(--app-accent)"
  >
    <div class="live-badge">
      Coming soon to iOS &middot; In Apple review
    </div>
  </PageHero>

  <main class="app-main">

    <hr class="section-divider">

    <div style="margin-bottom:0.5rem">
      <div class="app-section-label">Always free &middot; runs on your device</div>
      <h2 class="app-section-title">Inspect on your device</h2>
      <p class="app-section-sub">Scanning, decoding, and risk analysis run entirely locally. No internet connection required. Nothing leaves your phone.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">01 · Capture</div>
        <div class="feature-title">QR Scanner</div>
        <div class="feature-desc">Point your camera at any QR code or barcode. Decodes instantly into URLs, Wi-Fi credentials, contacts, calendar events, SMS, email, geo, crypto, scripts, and plain text. Fully offline.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">02 · Inspect</div>
        <div class="feature-title">Paste &amp; Inspect</div>
        <div class="feature-desc">Paste any link or share it from another app. SafeOpen normalizes the URL, classifies the payload, and shows you the destination before you do anything with it.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">03 · Risk</div>
        <div class="feature-title">Local Risk Scoring</div>
        <div class="feature-desc">Heuristics flag raw IP addresses, punycode lookalike domains, unusual ports, suspicious path keywords, excessive query parameters, executable scripts, and known URL shorteners.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">04 · Explain</div>
        <div class="feature-title">Plain-language Explanation</div>
        <div class="feature-desc">No jargon. Every risk flag comes with a clear explanation of why it matters. You decide with full context, not just a colored badge.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">05 · Strip</div>
        <div class="feature-title">Tracking-parameter Stripping</div>
        <div class="feature-desc">Detects and removes 38+ known tracking parameters (UTM, fbclid, gclid, msclkid, and more). Shows the clean URL alongside the original so you can copy it without the surveillance baggage.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">06 · History</div>
        <div class="feature-title">Local Scan History</div>
        <div class="feature-desc">Every inspection is saved on your device. Review, copy, or share any past result. History never syncs to iCloud and never leaves your phone.</div>
      </div>
    </div>

    <hr class="section-divider">

    <div style="margin-bottom:0.5rem">
      <div class="app-section-label">Costs 1 credit each</div>
      <h2 class="app-section-title">Two features that need our servers</h2>
      <p class="app-section-sub">When you want more than just heuristics, two features call Katafract&rsquo;s backend. They cost 1 scan credit each. Nothing else costs anything.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">07 · Summary</div>
        <div class="feature-title">AI Summary</div>
        <div class="feature-desc">Our servers fetch the destination through a Katafract relay and use OpenAI to generate a plain-English summary of what the link contains. The destination never sees your IP.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">08 · Relay</div>
        <div class="feature-title">Open Safely</div>
        <div class="feature-desc">Open the link inside an isolated, non-persistent in-app browser served from a Katafract relay. Each session gets a disposable IPv6 address that the destination sees instead of your real IP, released after 10 minutes. Cookies and storage are destroyed when the session ends.</div>
      </div>
    </div>

    <hr class="section-divider">

    <div style="margin-bottom:0.5rem">
      <div class="app-section-label">Pay only for what you use</div>
      <h2 class="app-section-title">Scan credits</h2>
      <p class="app-section-sub">Every install starts with 10 free credits. We add 10 more every 30 days. If you need more, three consumable credit packs are available as one-time in-app purchases. Credits never expire. There is no subscription.</p>
    </div>

    <div class="pack-grid">
      <div class="pack-card">
        <div class="pack-label">Starter</div>
        <div class="pack-credits">100</div>
        <div class="pack-credits-label">scan credits</div>
        <div class="pack-price">$0.99</div>
        <div class="pack-per">$0.0099 per credit</div>
      </div>
      <div class="pack-card feature">
        <div class="pack-best">Best Value</div>
        <div class="pack-label">Standard</div>
        <div class="pack-credits">500</div>
        <div class="pack-credits-label">scan credits</div>
        <div class="pack-price">$2.99</div>
        <div class="pack-per">$0.006 per credit</div>
      </div>
      <div class="pack-card">
        <div class="pack-label">Power</div>
        <div class="pack-credits">2,000</div>
        <div class="pack-credits-label">scan credits</div>
        <div class="pack-price">$9.99</div>
        <div class="pack-per">$0.005 per credit</div>
      </div>
    </div>

    <hr class="section-divider">

    <div style="margin-bottom:0.5rem">
      <div class="app-section-label">How it works</div>
      <h2 class="app-section-title">Scan. Inspect. Decide.</h2>
    </div>

    <div class="steps">
      <div class="step">
        <div class="step-num">01</div>
        <div class="step-body">
          <h3>Scan or paste</h3>
          <p>Point the camera at a QR code or barcode, paste a link, or share one from any app. SafeOpen decodes it instantly with no internet connection required.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">02</div>
        <div class="step-body">
          <h3>Inspect locally</h3>
          <p>SafeOpen classifies the payload, normalizes the URL, strips tracking parameters, and runs local risk heuristics. You see the destination, the clean URL, the risk level, and a plain-language explanation of every flag. None of this costs a credit.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">03</div>
        <div class="step-body">
          <h3>Spend a credit when it matters</h3>
          <p>Tap AI Summary to spend 1 credit on a server-side summary of the destination, or tap Open Safely to view the page through Katafract&rsquo;s privacy relay in an isolated session. Both keep your device&rsquo;s IP off the destination&rsquo;s logs.</p>
        </div>
      </div>
    </div>

    <hr class="section-divider">

    <div style="margin-bottom:0.5rem">
      <div class="app-section-label">Try it yourself</div>
      <h2 class="app-section-title">Four QR codes, four outcomes</h2>
      <p class="app-section-sub">Scan any of these with SafeOpen to see how the app evaluates links before you open them.</p>
    </div>

    <div class="qr-demo-grid">
      <div class="qr-demo-card">
        <img src="/images/safeopen/safeopen-qr-safe.png" alt="Safe QR code — apple.com">
        <span class="qr-demo-badge qr-badge-safe">Safe</span>
        <div class="qr-demo-dest">apple.com</div>
        <div class="qr-demo-result">HTTPS, well-known domain — green indicator, clean preview.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/safeopen-qr-neutral.png" alt="Neutral QR code — example.com">
        <span class="qr-demo-badge qr-badge-neutral">Neutral</span>
        <div class="qr-demo-dest">example.com</div>
        <div class="qr-demo-result">HTTPS, placeholder domain — no risk flags, neutral indicator.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/safeopen-qr-medium.png" alt="Medium risk QR code — bit.ly shortener">
        <span class="qr-demo-badge qr-badge-medium">Caution</span>
        <div class="qr-demo-dest">bit.ly/3SafeOpen</div>
        <div class="qr-demo-result">URL shortener — destination hidden. Yellow caution, shortener flag.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/safeopen-qr-risky.png" alt="High risk QR code — raw IP address">
        <span class="qr-demo-badge qr-badge-high">High Risk</span>
        <div class="qr-demo-dest">192.0.2.1/account/verify</div>
        <div class="qr-demo-result">Raw IP address + HTTP + suspicious path — direct high-risk flag, red warning.</div>
      </div>
    </div>

    <hr class="section-divider">

    <div style="margin-bottom:0.5rem">
      <div class="app-section-label">Every QR code type, decoded</div>
      <h2 class="app-section-title">Not just URLs</h2>
      <p class="app-section-sub">SafeOpen decodes every QR code format you'll encounter in the real world. Scan these to see how each payload type is presented.</p>
    </div>

    <div class="qr-demo-grid" style="grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));">
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-url-safe.png" alt="URL QR code">
        <span class="qr-demo-badge qr-badge-safe">URL</span>
        <div class="qr-demo-dest">katafract.com/apps/safeopen</div>
        <div class="qr-demo-result">Standard HTTPS link — full inspection, risk score, clean URL.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-shorturl.png" alt="Short URL QR code">
        <span class="qr-demo-badge qr-badge-medium">Short URL</span>
        <div class="qr-demo-dest">tinyurl.com/…</div>
        <div class="qr-demo-result">Shortened link — destination unknown until expanded. Caution flag.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-url-risky.png" alt="Risky URL QR code">
        <span class="qr-demo-badge qr-badge-high">Risky URL</span>
        <div class="qr-demo-dest">198.51.100.42:8080/login</div>
        <div class="qr-demo-result">Raw IP + non-standard port + login path — multiple red flags.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-punycode.png" alt="Punycode domain QR code">
        <span class="qr-demo-badge qr-badge-high">Lookalike</span>
        <div class="qr-demo-dest">xn--pple-43d.com</div>
        <div class="qr-demo-result">Punycode domain masquerading as a well-known brand.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-wifi.png" alt="Wi-Fi QR code">
        <span class="qr-demo-badge qr-badge-neutral">Wi-Fi</span>
        <div class="qr-demo-dest">CoffeeShopGuest · WPA</div>
        <div class="qr-demo-result">Network name, security type, and password shown before you join.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-contact.png" alt="vCard QR code">
        <span class="qr-demo-badge qr-badge-neutral">Contact</span>
        <div class="qr-demo-dest">vCard / MECARD</div>
        <div class="qr-demo-result">Name, org, phone, and email displayed before adding to contacts.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-calendar.png" alt="Calendar QR code">
        <span class="qr-demo-badge qr-badge-neutral">Calendar</span>
        <div class="qr-demo-dest">VEVENT</div>
        <div class="qr-demo-result">Event title, date, and duration shown before adding to calendar.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-sms.png" alt="SMS QR code">
        <span class="qr-demo-badge qr-badge-neutral">SMS</span>
        <div class="qr-demo-dest">+1 555 000 1234</div>
        <div class="qr-demo-result">Phone number and pre-filled message shown before sending.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-email.png" alt="Email QR code">
        <span class="qr-demo-badge qr-badge-neutral">Email</span>
        <div class="qr-demo-dest">hello@example.com</div>
        <div class="qr-demo-result">Recipient, subject, and body shown before opening Mail.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-phone.png" alt="Phone QR code">
        <span class="qr-demo-badge qr-badge-neutral">Phone</span>
        <div class="qr-demo-dest">tel:+15550001234</div>
        <div class="qr-demo-result">Full number displayed before initiating a call.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-geo.png" alt="Geo QR code">
        <span class="qr-demo-badge qr-badge-neutral">Location</span>
        <div class="qr-demo-dest">40.7128, -74.0060</div>
        <div class="qr-demo-result">Coordinates shown with option to open in Maps.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-crypto.png" alt="Crypto wallet QR code">
        <span class="qr-demo-badge qr-badge-medium">Crypto</span>
        <div class="qr-demo-dest">bitcoin:1A1zP1…</div>
        <div class="qr-demo-result">Wallet address decoded and displayed. Verify before sending funds.</div>
      </div>
      <div class="qr-demo-card">
        <img src="/images/safeopen/type-text.png" alt="Plain text QR code">
        <span class="qr-demo-badge qr-badge-neutral">Plain Text</span>
        <div class="qr-demo-dest">Hello, world!</div>
        <div class="qr-demo-result">Raw text content shown in full with copy button.</div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="privacy-block">
      <h2>100% transparency on what we collect</h2>
      <p>The on-device features (scan, decode, risk score, strip trackers, history) make zero network calls. We receive nothing.</p>
      <p>The two credit features (AI Summary, Open Safely) send the URL you submitted plus an anonymous device UUID to Katafract. The URL is logged for 30 days for abuse prevention and then deleted by an automated job. The device UUID is stored in your Keychain only so we can track your credit balance. None of it is linked to your Apple ID, name, or email.</p>
      <p>For AI Summary, the fetched page text is sent to OpenAI under their API terms. No personal information is ever sent to OpenAI.</p>
      <p>SafeOpen contains no advertising SDKs, no analytics, and no crash reporters. We do not sell or share data with anyone for any purpose. Full disclosure on the <a href="/privacy/safeopen">SafeOpen Privacy Policy</a> page.</p>
      <div class="privacy-pills">
        <span class="privacy-pill">No accounts</span>
        <span class="privacy-pill">No iCloud sync</span>
        <span class="privacy-pill">No analytics</span>
        <span class="privacy-pill">30-day audit window</span>
        <span class="privacy-pill">URLs not linked to identity</span>
      </div>
    </div>

    <hr class="section-divider">

    <div>
      <div class="app-section-label">More from Katafract</div>
      <p class="app-section-sub">SafeOpen is part of a family of privacy-first iOS utilities. <a href="/apps/exifarmor">ExifArmor</a> strips hidden metadata from photos before you share them. <a href="/apps/parkarmor">ParkArmor</a> saves your parking spot with no account required. All built on the same principle: your data stays yours.</p>
    </div>

    <hr class="section-divider">

    <div style="text-align:center;padding:1rem 0 2rem">
      <div style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--dim2);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.75rem">Coming soon</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--text);margin-bottom:0.25rem">SafeOpen for iOS</div>
      <div style="font-family:'JetBrains Mono',monospace;font-size:0.85rem;color:var(--dim);margin-bottom:1.25rem">In Apple review queue &middot; iOS 17+ &middot; iPhone &amp; iPad</div>
      <a href="/#signup" class="btn-appstore plausible-event-name=notify_safeopen" style="margin-bottom:1.25rem">
        Get notified when it ships &rarr;
      </a>
      <div style="margin-top:0.75rem;font-size:0.85rem;color:var(--dim)">Android? <a href="/android/" style="color:var(--safeopen)">Join the waitlist →</a></div>
      <div style="font-size:0.8rem;color:var(--dim2);margin-top:1.25rem">
        <a href="/privacy/safeopen">Privacy Policy</a> &middot;
        <a href="/terms/safeopen">Terms of Service</a> &middot;
        <a href="/support/safeopen">Support</a>
      </div>
