---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---
<Base
  title="DocArmor — Your IDs, encrypted, on your device"
  description="DocArmor stores your IDs, insurance cards, and passports in an AES-256 encrypted vault locked behind Face ID. Nothing ever leaves your device. Coming soon."
  ogDescription="AES-256 encrypted document vault. Face ID protected. iCloud sync disabled. Your most sensitive IDs stay on your device. Coming soon from Katafract."
  section="apps"
  twitterCard="summary_large_image"
>
  <link slot="head" rel="stylesheet" href="/style.css" />

  <style slot="head" is:global>
    /* DocArmor accent — violet */
    :root { --app-accent: var(--docarmor); }
    /* .app-main / .section-divider / .app-section-{label,title,sub} live in /style.css */
    .coming-soon-badge { display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; padding: 0.6rem 1.25rem; border-radius: 999px; background: rgba(232,121,249,0.07); border: 1px solid rgba(232,121,249,0.2); color: var(--app-accent); margin-bottom: 3rem; }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin: 2rem 0 3rem; }
    .feature-card { background: rgba(10,10,20,0.5); border: 1px solid var(--border); border-radius: 1rem; padding: 1.5rem; transition: border-color 0.2s; }
    .feature-card:hover { border-color: rgba(232,121,249,0.2); }
    .feature-icon { font-family: 'JetBrains Mono', monospace; font-size: 0.7rem; color: var(--app-accent); letter-spacing: 0.2em; text-transform: uppercase; margin-bottom: 0.85rem; opacity: 0.85; }
    .feature-title { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600; color: var(--text); margin-bottom: 0.4rem; }
    .feature-desc { font-size: 0.875rem; color: var(--dim); line-height: 1.65; }
    .privacy-block { background: rgba(232,121,249,0.03); border: 1px solid rgba(232,121,249,0.1); border-radius: 1rem; padding: 2rem; margin: 2rem 0; }
    .privacy-block h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.35rem; font-weight: 600; color: var(--text); margin-bottom: 0.75rem; }
    .privacy-block p { font-size: 0.9rem; color: var(--dim); line-height: 1.7; margin-bottom: 0.5rem; }
    .privacy-block p:last-child { margin-bottom: 0; }
    .privacy-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
    .privacy-pill { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; padding: 0.25rem 0.75rem; border-radius: 999px; background: rgba(232,121,249,0.06); border: 1px solid rgba(232,121,249,0.15); color: var(--app-accent); }
  </style>

  <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "DocArmor",
      "operatingSystem": "iOS",
      "applicationCategory": "SecurityApplication",
      "description": "AES-256 encrypted document vault for your IDs, insurance cards, and passports. Face ID protected. Nothing leaves your device.",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "USD",
        "price": "7.99",
        "description": "One-time unlock"
      },
      "author": {
        "@type": "Organization",
        "name": "Katafract LLC"
      }
    }
  </script>

  <PageHero
    eyebrow="DocArmor · by Katafract"
    title="Your IDs, <em>encrypted</em>,<br>on your device"
    subhead="Your driver's license, insurance cards, and passport are probably sitting unencrypted in your camera roll right now — syncing to iCloud, visible in shared albums. DocArmor scans, encrypts, and locks them behind Face ID. Nothing ever leaves your phone."
    accent="var(--docarmor)"
  >
    <div class="coming-soon-badge">
      Coming soon to the App Store
    </div>
    <div style="text-align:center;margin-top:1rem">
      <p style="font-size:0.875rem"><a href="/android/" class="plausible-event-name=DocArmor+Interest" style="color:var(--docarmor)">Android? Join the waitlist →</a></p>
    </div>
  </PageHero>

  <main class="app-main">

    <hr class="section-divider">

    <div style="margin-bottom:0.5rem">
      <div class="app-section-label">Features</div>
      <h2 class="app-section-title">The vault your documents deserve</h2>
      <p class="app-section-sub">Built for documents you can&rsquo;t afford to lose &mdash; or expose.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">01 · Capture</div>
        <div class="feature-title">Built-In Scanner</div>
        <div class="feature-desc">Scan documents directly in-app. VisionKit processes the camera feed on-device. Scans are encrypted before they ever touch disk.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">02 · Encryption</div>
        <div class="feature-title">AES-256 Encryption</div>
        <div class="feature-desc">Every document is encrypted with AES-256 via Apple CryptoKit. The encryption key lives in the iOS Keychain and never leaves your device.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">03 · Auth</div>
        <div class="feature-title">Face ID / Touch ID</div>
        <div class="feature-desc">Your vault locks when you leave the app and requires biometric authentication to reopen. DocArmor never sees your biometric data &mdash; only iOS does.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">04 · Backup</div>
        <div class="feature-title">Optional Cloud Backup</div>
        <div class="feature-desc">Add a Sovereign subscription (through Vaultyx) and DocArmor can back up to Katafract&rsquo;s zero-knowledge Shards S3 &mdash; encrypted on-device, never visible to us. Off by default, off on iCloud, off on Apple.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">05 · Sort</div>
        <div class="feature-title">Organized Folders</div>
        <div class="feature-desc">Create categories like Medical, Travel, or Finance. Every folder uses the same vault key. Everything stays encrypted.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">06 · Export</div>
        <div class="feature-title">Secure Export</div>
        <div class="feature-desc">Share a document to Files, AirDrop, or another app when you need it. Export is always explicit &mdash; nothing leaves without your action.</div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="privacy-block">
      <h2>Zero-knowledge by default</h2>
      <p>DocArmor encrypts every document with AES-256 before it touches disk. The key is in the iOS Keychain, bound to your device and biometrics. Without Sovereign, there are no servers at all &mdash; Katafract never sees your vault.</p>
      <p>If you turn on Sovereign cloud backup, files are re-encrypted locally with a Sovereign-derived key and uploaded as opaque chunks to Shards S3. Katafract still can&rsquo;t read them &mdash; the encryption happens on your device, before upload.</p>
      <p>Apple Privacy Nutrition Label: <strong>Data Not Collected.</strong></p>
      <div class="privacy-pills">
        <span class="privacy-pill">AES-256 on-device</span>
        <span class="privacy-pill">Face ID protected</span>
        <span class="privacy-pill">Cloud backup opt-in</span>
        <span class="privacy-pill">Zero-knowledge Shards</span>
        <span class="privacy-pill">No iCloud sync</span>
      </div>
    </div>

    <hr class="section-divider">

    <div class="privacy-block">
      <h2>Not a legal substitute</h2>
      <p>DocArmor is a personal-document management tool. A digital copy in DocArmor does not replace the physical passport, license, or ID you need to cross a border, board a flight, or satisfy official identification.</p>
    </div>

    <hr class="section-divider">

    <div class="callout">
      <p><strong>Free to start, one-time $7.99 unlock available.</strong> Download DocArmor free and use basic features offline: encrypted storage, Face ID unlock, folders. Unlock all features with a one-time in-app purchase. Because your vault is encrypted locally, <strong>uninstalling the app permanently deletes all vault contents</strong> &mdash; export anything important before uninstalling.</p>
      <p style="margin-top:0.75rem"><strong>Want cloud backup?</strong> Add <a href="/apps/vaultyx" style="color:var(--docarmor)">Sovereign</a> (purchased in Vaultyx) and DocArmor gains encrypted cloud sync through Katafract Shards. Same zero-knowledge promise &mdash; encryption happens before upload. <a href="/pricing">View pricing →</a></p>
      <p style="margin-top:0.75rem;margin-bottom:0"><a href="/terms/docarmor">Full Terms of Service &rarr;</a></p>
    </div>

    <hr class="section-divider">

    <div style="text-align:center;padding:1rem 0 2rem">
      <div style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--dim2);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.75rem">On the App Store</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--text);margin-bottom:0.5rem">Free &middot; iOS &middot; iPhone &amp; iPad</div>
      <div style="font-size:0.875rem;color:var(--dim)">Optional cloud backup via Sovereign in <a href="/apps/vaultyx" style="color:var(--docarmor)">Vaultyx</a></div>
    </div>

  </main>
</Base>
