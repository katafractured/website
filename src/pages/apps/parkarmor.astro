---
import Base from '../../layouts/Base.astro';
---
<Base
  title="ParkArmor — Never lose your car again"
  description="ParkArmor saves your parking spot with one tap. Walking directions back, parking timer, lock screen widget. Your location never leaves your device — free on the App Store."
  ogDescription="One tap saves your parking spot. Walking directions back, parking timer, lock screen widget. No accounts, no cloud. Free on the App Store."
  ogImage="https://katafract.com/images/og-parkarmor.jpg"
  section="apps"
  twitterCard="summary_large_image"
>
  <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "ParkArmor",
      "applicationCategory": "UtilitiesApplication",
      "operatingSystem": "iOS",
      "description": "Save your parking spot with one tap. Walking directions back, timer, lock screen widget. Your location never leaves your device.",
      "offers": [
        { "@type": "Offer", "price": "0", "priceCurrency": "USD", "name": "Free" },
        { "@type": "Offer", "price": "3.99", "priceCurrency": "USD", "name": "Pro" }
      ],
      "url": "https://apps.apple.com/app/id6760988040",
      "downloadUrl": "https://apps.apple.com/app/id6760988040"
    }
  </script>

  <style slot="head" is:global>
    :root { --app-accent: var(--parkarmor); }
    .app-hero { padding: 4rem 1.5rem 3rem; max-width: 900px; margin: 0 auto; }
    .app-main { max-width: 900px; margin: 0 auto; padding: 0 1.5rem 5rem; }
    .app-hero-eyebrow {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--app-accent);
      letter-spacing: 0.3em;
      text-transform: uppercase;
      margin-bottom: 1.25rem;
      display: flex;
      align-items: center;
      gap: 0.75rem;
    }
    .app-hero-eyebrow .back-link { color: var(--dim2); font-size: 0.65rem; letter-spacing: 0.15em; }
    .app-hero-eyebrow .back-link:hover { color: var(--dim); text-decoration: none; }
    .app-hero h1 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(2.8rem, 6vw, 4rem);
      font-weight: 700;
      line-height: 1.08;
      letter-spacing: -0.01em;
      margin-bottom: 1.25rem;
    }
    .app-hero h1 em { font-style: normal; color: var(--app-accent); }
    .app-hero .tagline { font-size: 1.1rem; color: var(--dim); line-height: 1.7; max-width: 580px; margin-bottom: 2.5rem; }
    .app-cta-row {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-wrap: wrap;
      margin-bottom: 3rem;
    }
    .btn-appstore {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: white;
      color: #050510;
      font-weight: 700;
      font-size: 0.9rem;
      padding: 0.8rem 1.75rem;
      border-radius: 999px;
      transition: background 0.15s;
    }
    .btn-appstore:hover { background: #e8e8e8; text-decoration: none; }
    .price-note {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      color: var(--dim2);
    }
    .section-divider { border: none; border-top: 1px solid var(--border); margin: 3.5rem 0; }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin: 2rem 0 3rem; }
    .feature-card { background: rgba(10,10,20,0.5); border: 1px solid var(--border); border-radius: 1rem; padding: 1.5rem; transition: border-color 0.2s; }
    .feature-card:hover { border-color: rgba(74,222,128,0.2); }
    .feature-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
    .feature-title { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600; color: var(--text); margin-bottom: 0.4rem; }
    .feature-desc { font-size: 0.875rem; color: var(--dim); line-height: 1.65; }
    .privacy-block { background: rgba(74,222,128,0.03); border: 1px solid rgba(74,222,128,0.1); border-radius: 1rem; padding: 2rem; margin: 2rem 0; }
    .privacy-block h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.35rem; font-weight: 600; color: var(--text); margin-bottom: 0.75rem; }
    .privacy-block p { font-size: 0.9rem; color: var(--dim); line-height: 1.7; margin-bottom: 0.5rem; }
    .privacy-block p:last-child { margin-bottom: 0; }
    .privacy-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
    .privacy-pill { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; padding: 0.25rem 0.75rem; border-radius: 999px; background: rgba(74,222,128,0.06); border: 1px solid rgba(74,222,128,0.15); color: var(--app-accent); }
    .app-section-label { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: var(--app-accent); letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 0.75rem; }
    .app-section-title { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
    .app-section-sub { font-size: 0.95rem; color: var(--dim); line-height: 1.7; }
    @media (min-width: 768px) {
      .app-hero { padding: 6rem 3.5rem 4.5rem; }
      .app-main { padding: 0 3.5rem 7rem; }
    }
    @media (min-width: 1100px) {
      .app-hero { padding: 7rem 5rem 5rem; }
      .app-main { padding: 0 5rem 8rem; }
    }
    @media (max-width: 480px) {
      .app-hero { padding: 3rem 1.25rem 2.5rem; }
      .app-main { padding: 0 1.25rem 4rem; }
    }
  </style>

  <div class="app-hero">
    <div class="app-hero-eyebrow">
      <span>ParkArmor</span>
      <span>&middot;</span>
      <a href="/" class="back-link">by Katafract &nearr;</a>
    </div>
    <h1>Never lose your<br><em>car</em> again</h1>
    <p class="tagline">One tap saves your parking spot. Get walking directions back, set a meter timer, and check your widget from the lock screen &mdash; all without an account, all without the cloud.</p>
    <div class="app-cta-row">
      <a href="https://apps.apple.com/app/id6760988040" class="btn-appstore plausible-event-name=AppStore+Click plausible-event-app=parkarmor">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 21.99 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09 21.99C7.79 22.03 6.8 20.68 5.96 19.47C4.25 16.97 2.94 12.45 4.7 9.39C5.57 7.87 7.13 6.91 8.82 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/></svg>
        Download on the App Store
      </a>
      <span class="price-note">Free · Pro available · Or bundled with Enclave · <a href="/pricing" style="color:var(--cyan)">See pricing</a></span>
    </div>
    <div style="margin-top:0.75rem;font-size:0.85rem;color:var(--dim)">Android? <a href="/android/" style="color:var(--parkarmor)">Join the waitlist →</a></div>
  </div>

  <main class="app-main">

    <hr class="section-divider">

    <div style="margin-bottom:0.5rem">
      <div class="app-section-label">Features</div>
      <h2 class="app-section-title">Everything you need to find your car</h2>
      <p class="app-section-sub">Simple enough to use in a hurry. Reliable enough to trust.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">&#x1F4CD;</div>
        <div class="feature-title">One-Tap Pin <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:var(--parkarmor);letter-spacing:0.05em">FREE</span></div>
        <div class="feature-desc">Tap once as you walk away. ParkArmor saves your current GPS location. The free tier always remembers your most recent spot.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F9ED;</div>
        <div class="feature-title">Walking Directions <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:var(--parkarmor);letter-spacing:0.05em">FREE</span></div>
        <div class="feature-desc">Tap &ldquo;Navigate Back&rdquo; to launch Apple Maps with walking directions to your exact spot. No fumbling, no searching.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x23F1;&#xFE0F;</div>
        <div class="feature-title">Parking Timer <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:var(--parkarmor);letter-spacing:0.05em">PRO</span></div>
        <div class="feature-desc">Set your meter expiry and get a local notification before time runs out. No server &mdash; the alert fires entirely on your device.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F4F1;</div>
        <div class="feature-title">Lock Screen Widget <span style="font-family:'JetBrains Mono',monospace;font-size:0.6rem;color:var(--parkarmor);letter-spacing:0.05em">PRO</span></div>
        <div class="feature-desc">See your saved spot and timer countdown without unlocking your phone. Multiple saved spots and full history also unlocked with Pro.</div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="privacy-block">
      <h2>&#x1F512; Your location never leaves your device</h2>
      <p>ParkArmor stores your parking location only in local device storage. It is never transmitted to Katafract, Apple, or anyone else. There are no servers, no cloud sync, and no location history retained anywhere outside your phone.</p>
      <p>Apple Privacy Nutrition Label: <strong>Data Not Collected.</strong></p>
      <div class="privacy-pills">
        <span class="privacy-pill">No data collected</span>
        <span class="privacy-pill">No accounts</span>
        <span class="privacy-pill">No cloud sync</span>
        <span class="privacy-pill">No location history</span>
        <span class="privacy-pill">Local notifications only</span>
      </div>
    </div>

    <hr class="section-divider">

    <div class="callout">
      <p><strong>Free to download.</strong> The free tier saves your most recent parking spot with one tap and provides walking directions back — no account, no purchase required. <strong>ParkArmor Pro (one-time) or subscribe to Enclave to unlock this and other Katafract apps.</strong> <a href="/pricing">View pricing →</a> Unlocks multiple saved spots, parking history, the meter timer with local notifications, and the lock screen widget. A permanent license tied to your Apple ID. GPS accuracy depends on your device and environment — always confirm your actual spot. Refunds are handled by Apple at <a href="https://reportaproblem.apple.com" target="_blank" rel="noopener">reportaproblem.apple.com</a>.</p>
      <p style="margin-top:0.75rem;margin-bottom:0"><a href="/terms/parkarmor">Full Terms of Service →</a></p>
    </div>

    <hr class="section-divider">

    <div style="text-align:center;padding:1rem 0 2rem">
      <a href="https://apps.apple.com/app/id6760988040" class="btn-appstore plausible-event-name=AppStore+Click plausible-event-app=parkarmor" style="margin-bottom:1rem">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 21.99 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09 21.99C7.79 22.03 6.8 20.68 5.96 19.47C4.25 16.97 2.94 12.45 4.7 9.39C5.57 7.87 7.13 6.91 8.82 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/></svg>
        Download on the App Store
      </a>
      <div style="font-family:'JetBrains Mono',monospace;font-size:0.72rem;color:var(--dim2)">Requires iOS 17.0 or later · iPhone</div>
    </div>

  </main>
</Base>
