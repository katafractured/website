---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---

<style is:global>
  .btn-appstore {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    background: white;
    color: #050510;
    font-weight: 700;
    font-size: 0.9rem;
    padding: 0.8rem 1.75rem;
    border-radius: 999px;
    transition: background 0.15s;
  }
  .btn-appstore:hover { background: #e8e8e8; text-decoration: none; }
</style>

<Base
  title="Vaultyx — Zero-Knowledge Cloud Storage by Katafract"
  description="Vaultyx is end-to-end encrypted cloud storage with client-side AES-256-GCM encryption. FastCDC delta sync. Routes through WraithVPN. Available now on the App Store."
  ogDescription="AES-256-GCM encrypted cloud storage. FastCDC delta sync. Automatic VPN routing. We never see your files. Available now."
  section="apps"
  twitterCard="summary_large_image"
>
  <style slot="head" is:global>
    .app-main { max-width: 900px; margin: 0 auto; padding: 0 1.5rem 5rem; }
    .coming-soon-badge { display: inline-flex; align-items: center; gap: 0.5rem; font-family: 'JetBrains Mono', monospace; font-size: 0.78rem; padding: 0.6rem 1.25rem; border-radius: 999px; background: rgba(255,0,110,0.07); border: 1px solid rgba(255,0,110,0.2); color: #FF006E; margin-top: 1.5rem; }
    .section-divider { border: none; border-top: 1px solid var(--border); margin: 3.5rem 0; }
    .features-grid { display: grid; grid-template-columns: repeat(auto-fit, minmax(220px, 1fr)); gap: 1rem; margin: 2rem 0 3rem; }
    .feature-card { background: rgba(10,10,20,0.5); border: 1px solid var(--border); border-radius: 1rem; padding: 1.5rem; transition: border-color 0.2s; }
    .feature-card:hover { border-color: rgba(255,0,110,0.2); }
    .feature-icon { font-size: 1.5rem; margin-bottom: 0.75rem; }
    .feature-title { font-family: 'Cormorant Garamond', serif; font-size: 1.2rem; font-weight: 600; color: var(--text); margin-bottom: 0.4rem; }
    .feature-desc { font-size: 0.875rem; color: var(--dim); line-height: 1.65; }
    .privacy-block { background: rgba(255,0,110,0.03); border: 1px solid rgba(255,0,110,0.1); border-radius: 1rem; padding: 2rem; margin: 2rem 0; }
    .privacy-block h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.35rem; font-weight: 600; color: var(--text); margin-bottom: 0.75rem; }
    .privacy-block p { font-size: 0.9rem; color: var(--dim); line-height: 1.7; margin-bottom: 0.5rem; }
    .privacy-block p:last-child { margin-bottom: 0; }
    .privacy-pills { display: flex; flex-wrap: wrap; gap: 0.5rem; margin-top: 1rem; }
    .privacy-pill { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; padding: 0.25rem 0.75rem; border-radius: 999px; background: rgba(255,0,110,0.06); border: 1px solid rgba(255,0,110,0.15); color: #FF006E; }
    .unlike-list { list-style: none; padding: 0; margin: 1rem 0 1.25rem; display: flex; flex-direction: column; gap: 0.6rem; }
    .unlike-list li { font-size: 0.9rem; color: var(--dim); line-height: 1.55; padding-left: 1.25rem; position: relative; }
    .unlike-list li::before { content: '—'; position: absolute; left: 0; color: var(--vaultyx, #FF006E); font-weight: 600; }
    .unlike-list li strong { color: var(--text); font-weight: 700; }
    .app-section-label { font-family: 'JetBrains Mono', monospace; font-size: 0.68rem; color: #FF006E; letter-spacing: 0.25em; text-transform: uppercase; margin-bottom: 0.75rem; }
    .app-section-title { font-family: 'Cormorant Garamond', serif; font-size: 1.6rem; font-weight: 700; color: var(--text); margin-bottom: 0.5rem; }
    .app-section-sub { font-size: 0.95rem; color: var(--dim); line-height: 1.7; }
    .comparison-block { background: rgba(255,0,110,0.02); border: 1px solid rgba(255,0,110,0.08); border-radius: 1rem; padding: 2rem; margin: 2rem 0; }
    .comparison-header { font-family: 'Cormorant Garamond', serif; font-size: 1.35rem; font-weight: 600; color: var(--text); margin-bottom: 1.5rem; text-align: center; }
    .comparison-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 1.5rem; }
    .comparison-item { display: flex; flex-direction: column; gap: 0.25rem; }
    .comparison-label { font-family: 'JetBrains Mono', monospace; font-size: 0.65rem; color: var(--dim2); text-transform: uppercase; letter-spacing: 0.08em; }
    .comparison-val { font-size: 0.95rem; color: var(--text); }
    @media (min-width: 768px) {
      .app-hero { padding: 6rem 3.5rem 4.5rem; }
      .app-main { padding: 0 3.5rem 7rem; }
    }
    @media (min-width: 1100px) {
      .app-hero { padding: 7rem 5rem 5rem; }
      .app-main { padding: 0 5rem 8rem; }
    }
    @media (max-width: 480px) {
      .app-hero { padding: 3rem 1.25rem 2.5rem; }
      .app-main { padding: 0 1.25rem 4rem; }
    }
  </style>

  <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "Vaultyx",
      "operatingSystem": "iOS, macOS",
      "applicationCategory": "SecurityApplication",
      "description": "Zero-knowledge encrypted cloud storage. Store documents, photos, and files with end-to-end encryption where only you hold the key.",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "USD",
        "price": "18.00",
        "description": "Sovereign subscription includes 1 TB storage"
      },
      "author": {
        "@type": "Organization",
        "name": "Katafract LLC"
      }
    }
  </script>

  <PageHero
    eyebrow="Vaultyx"
    title="Your files, <em>encrypted</em>,<br>on your terms"
    subhead="Encrypted cloud storage where only you hold the key. AES-256-GCM encryption, FastCDC delta sync, and automatic VPN routing — we never see your files, ever. Backup photos, documents, and videos with confidence."
    accent="var(--vaultyx)"
  >
    <div style="margin-top:2rem">
      <a href="https://apps.apple.com/app/id6748858213" class="btn-appstore plausible-event-name=AppStore+Click plausible-event-app=vaultyx" target="_blank" rel="noopener">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor" aria-hidden="true"><path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 21.99 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09 21.99C7.79 22.03 6.8 20.68 5.96 19.47C4.25 16.97 2.94 12.45 4.7 9.39C5.57 7.87 7.13 6.91 8.82 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/></svg>
        Download on the App Store
      </a>
      <div style="margin-top:1rem;font-size:0.9rem;color:var(--dim)">Android? <a href="/android/" style="color:var(--vaultyx)">Join the waitlist →</a></div>
    </div>
  </PageHero>

  <main class="app-main">

    <hr class="section-divider">

    <div style="margin-bottom:0.5rem">
      <div class="app-section-label">Features</div>
      <h2 class="app-section-title">Storage built around privacy</h2>
      <p class="app-section-sub">Zero-knowledge by design. We cannot read your files, even if we wanted to.</p>
    </div>

    <div class="features-grid">
      <div class="feature-card">
        <div class="feature-icon">🔐</div>
        <div class="feature-title">AES-256-GCM Encryption</div>
        <div class="feature-desc">Military-grade encryption on your device. Your encryption key never leaves your possession. Katafract stores only encrypted blobs.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">⚡</div>
        <div class="feature-title">FastCDC Delta Sync</div>
        <div class="feature-desc">Edit 1 byte of a 1GB file? Only ~64KB uploads. Content-defined chunking means you only sync what changed, not the entire file.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🔄</div>
        <div class="feature-title">Auto VPN Routing</div>
        <div class="feature-desc">All traffic routes through WraithVPN automatically. Your ISP sees the WireGuard tunnel, not your files or metadata.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📸</div>
        <div class="feature-title">Photo Backup</div>
        <div class="feature-desc">Backup original-quality photos and videos. Automatic deduplication by content hash — store the same photo once, even across devices.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">📦</div>
        <div class="feature-title">Standard S3 Backend</div>
        <div class="feature-desc">Your data lives in standard S3. Export anytime with any S3 client. No lock-in, no proprietary APIs — just open standards.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">🌍</div>
        <div class="feature-title">Distributed Globally</div>
        <div class="feature-desc">Data replicated across US, EU, and Asia. 500Mbps+ unmetered bandwidth per node. Automatic failover, zero manual intervention.</div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="privacy-block">
      <h2>🔒 Mathematically impossible to scan</h2>
      <p>Vaultyx uses client-side encryption. The server never receives your unencrypted data, never holds your encryption keys, and has no way to read your files. Content scanning, AI training, warrant compliance — all mathematically impossible without your key.</p>
      <ul class="unlike-list">
        <li><strong>Unlike iCloud:</strong> Apple scans photos before they upload. We never see anything to scan.</li>
        <li><strong>Unlike Dropbox:</strong> We have no plaintext copy on servers. Ever.</li>
        <li><strong>Unlike Google Drive:</strong> No content analysis, no AI training, no account profiles built from your data.</li>
      </ul>
      <div class="privacy-pills">
        <span class="privacy-pill">AES-256-GCM encrypted</span>
        <span class="privacy-pill">Client-side only</span>
        <span class="privacy-pill">No server-side keys</span>
        <span class="privacy-pill">No content scanning</span>
        <span class="privacy-pill">Zero logs</span>
      </div>
    </div>

    <hr class="section-divider">

    <div class="comparison-block">
      <div class="comparison-header">How Vaultyx compares</div>
      <div class="comparison-grid">
        <div class="comparison-item">
          <div class="comparison-label">Encryption</div>
          <div class="comparison-val">AES-256-GCM client-side</div>
        </div>
        <div class="comparison-item">
          <div class="comparison-label">Delta Sync</div>
          <div class="comparison-val">FastCDC (only changed chunks)</div>
        </div>
        <div class="comparison-item">
          <div class="comparison-label">Server Access</div>
          <div class="comparison-val">Encrypted blobs only</div>
        </div>
        <div class="comparison-item">
          <div class="comparison-label">Content Scanning</div>
          <div class="comparison-val">Impossible — server can't read</div>
        </div>
        <div class="comparison-item">
          <div class="comparison-label">Data Export</div>
          <div class="comparison-val">Standard S3 API</div>
        </div>
        <div class="comparison-item">
          <div class="comparison-label">Storage Replication</div>
          <div class="comparison-val">3x across geographic zones</div>
        </div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="callout">
      <p><strong>Included with Sovereign subscription</strong> — see <a href="/pricing">current pricing</a>. Vaultyx comes with 1TB of encrypted storage, automatic VPN routing, and synced across all your devices.</p>
      <p style="margin-top:0.75rem;margin-bottom:0"><a href="/pricing" class="plausible-event-name=Sovereign+CTA plausible-event-app=vaultyx">See Sovereign tier →</a></p>
    </div>

    <hr class="section-divider">

    <div style="text-align:center;padding:1rem 0 2rem">
      <div style="font-family:'JetBrains Mono',monospace;font-size:0.68rem;color:var(--dim2);letter-spacing:0.15em;text-transform:uppercase;margin-bottom:0.75rem">Included with Sovereign</div>
      <div style="font-family:'Cormorant Garamond',serif;font-size:1.5rem;color:var(--text);margin-bottom:0.5rem">1TB encrypted storage · Zero-knowledge</div>
      <div style="font-size:0.875rem;color:var(--dim)">iOS available now · macOS + Android coming</div>
    </div>

  </main>
</Base>
