---
import Base from '../../layouts/Base.astro';
import PageHero from '../../components/PageHero.astro';
---
<Base
  title="WraithVPN — WireGuard VPN"
  description="Wraith is a privacy-first VPN built on WireGuard. No logs, no tracking, no compromise. Global nodes across EU, US, and Asia. Haven DNS included. Built by people who refuse to be the product."
  ogDescription="Privacy-first VPN. No logs, no tracking, no compromise. WireGuard-based, global nodes across EU, US, and Asia, Haven DNS built-in. Available on iOS."
  ogImage="https://katafract.com/images/og-wraith.jpg"
  section="apps"
  twitterCard="summary_large_image"
>
  <style slot="head" is:global>
    /* Wraith brand override — purple accent instead of cyan */
    :root {
      --wraith: #818CF8;
      --wraith-dim: rgba(129,140,248,0.12);
      --wraith-border: rgba(129,140,248,0.2);
      --wraith-glow: rgba(129,140,248,0.06);
    }

    /* App main container */
    .app-main { max-width: 960px; margin: 0 auto; padding: 0 1.5rem 5rem; }

    .app-cta-row {
      display: flex;
      align-items: center;
      gap: 1.25rem;
      flex-wrap: wrap;
      margin-bottom: 3rem;
    }

    .btn-appstore {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: white;
      color: #050510;
      font-weight: 700;
      font-size: 0.9rem;
      padding: 0.8rem 1.75rem;
      border-radius: 999px;
      transition: background 0.15s;
    }
    .btn-appstore:hover { background: #e8e8e8; text-decoration: none; }

    .btn-secondary {
      display: inline-flex;
      align-items: center;
      gap: 0.5rem;
      background: var(--wraith-dim);
      color: var(--wraith);
      border: 1px solid var(--wraith-border);
      font-weight: 600;
      font-size: 0.875rem;
      padding: 0.75rem 1.5rem;
      border-radius: 999px;
      transition: background 0.15s, border-color 0.15s;
    }
    .btn-secondary:hover { background: rgba(129,140,248,0.18); text-decoration: none; }

    .price-note {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.78rem;
      color: var(--dim2);
    }

    /* Live badge */
    .live-badge {
      display: inline-flex;
      align-items: center;
      gap: 0.4rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      color: #33E8A0;
      background: rgba(51,232,160,0.08);
      border: 1px solid rgba(51,232,160,0.18);
      border-radius: 999px;
      padding: 0.2rem 0.65rem;
      letter-spacing: 0.1em;
      text-transform: uppercase;
    }
    .live-dot {
      width: 6px;
      height: 6px;
      border-radius: 50%;
      background: #33E8A0;
      animation: pulse-green 2s infinite;
    }
    @keyframes pulse-green {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.35; }
    }

    /* Divider */
    .section-divider {
      border: none;
      border-top: 1px solid var(--border);
      margin: 3.5rem 0;
    }

    /* Features */
    .features-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(240px, 1fr));
      gap: 1rem;
      margin: 2rem 0 3rem;
    }
    .feature-card {
      background: var(--wraith-glow);
      border: 1px solid var(--border);
      border-radius: 1rem;
      padding: 1.5rem;
      transition: border-color 0.2s;
    }
    .feature-card:hover { border-color: var(--wraith-border); }
    .feature-icon { font-size: 1.4rem; margin-bottom: 0.75rem; }
    .feature-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.2rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.4rem;
    }
    .feature-desc {
      font-size: 0.875rem;
      color: var(--dim);
      line-height: 1.65;
    }

    /* Section headings */
    .app-page-section { margin-bottom: 0.5rem; }
    .app-section-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      color: var(--wraith);
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 0.75rem;
    }
    .app-section-title {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.7rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.5rem;
    }
    .app-section-sub {
      font-size: 0.95rem;
      color: var(--dim);
      line-height: 1.7;
      margin-bottom: 0;
    }

    /* Node grid */
    .nodes-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(160px, 1fr));
      gap: 0.75rem;
      margin: 1.75rem 0 2.5rem;
    }
    .node-card {
      background: rgba(10,10,20,0.6);
      border: 1px solid var(--border);
      border-radius: 0.875rem;
      padding: 1.1rem 1.25rem;
      transition: border-color 0.2s;
    }
    .node-card:hover { border-color: var(--wraith-border); }
    .node-region {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      color: var(--wraith);
      letter-spacing: 0.15em;
      text-transform: uppercase;
      margin-bottom: 0.4rem;
    }
    .node-name {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.1rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.2rem;
    }
    .node-city {
      font-size: 0.8rem;
      color: var(--dim2);
    }
    .node-status {
      display: inline-flex;
      align-items: center;
      gap: 0.3rem;
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.6rem;
      color: #33E8A0;
      margin-top: 0.6rem;
    }
    .node-dot {
      width: 5px;
      height: 5px;
      border-radius: 50%;
      background: #33E8A0;
    }

    /* Manifesto / privacy block */
    .manifesto {
      background: var(--wraith-glow);
      border: 1px solid var(--wraith-border);
      border-radius: 1rem;
      padding: 2.25rem 2rem;
      margin: 2rem 0;
    }
    .manifesto-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      color: var(--wraith);
      letter-spacing: 0.25em;
      text-transform: uppercase;
      margin-bottom: 1rem;
    }
    .manifesto h2 {
      font-family: 'Cormorant Garamond', serif;
      font-size: clamp(1.5rem, 3vw, 2rem);
      font-weight: 700;
      color: var(--text);
      line-height: 1.25;
      margin-bottom: 1.25rem;
    }
    .manifesto p {
      font-size: 0.9rem;
      color: var(--dim);
      line-height: 1.8;
      margin-bottom: 0.75rem;
    }
    .manifesto p:last-of-type { margin-bottom: 0; }

    .privacy-pills {
      display: flex;
      flex-wrap: wrap;
      gap: 0.5rem;
      margin-top: 1.25rem;
    }
    .privacy-pill {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.68rem;
      padding: 0.25rem 0.75rem;
      border-radius: 999px;
      background: rgba(51,232,160,0.06);
      border: 1px solid rgba(51,232,160,0.15);
      color: #33E8A0;
    }

    /* How it works steps */
    .steps {
      display: flex;
      flex-direction: column;
      gap: 1.5rem;
      margin: 2rem 0 3rem;
    }
    .step { display: flex; gap: 1.25rem; align-items: flex-start; }
    .step-num {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.7rem;
      color: var(--wraith);
      background: var(--wraith-dim);
      border: 1px solid var(--wraith-border);
      border-radius: 50%;
      width: 32px;
      height: 32px;
      display: flex;
      align-items: center;
      justify-content: center;
      flex-shrink: 0;
      margin-top: 2px;
    }
    .step-body h3 {
      font-family: 'Cormorant Garamond', serif;
      font-size: 1.15rem;
      font-weight: 600;
      color: var(--text);
      margin-bottom: 0.3rem;
    }
    .step-body p {
      font-size: 0.9rem;
      color: var(--dim);
      line-height: 1.65;
      margin: 0;
    }

    /* Pricing */
    .pricing-grid {
      display: grid;
      grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
      gap: 1rem;
      margin: 2rem 0 2.5rem;
    }
    .plan-card {
      background: rgba(10,10,20,0.5);
      border: 1px solid var(--border);
      border-radius: 1rem;
      padding: 1.75rem 1.5rem;
    }
    .plan-card.featured {
      background: var(--wraith-glow);
      border-color: var(--wraith-border);
    }
    .plan-label {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      letter-spacing: 0.12em;
      text-transform: uppercase;
      margin-bottom: 0.5rem;
      color: var(--dim2);
    }
    .plan-card.featured .plan-label { color: var(--wraith); }
    .plan-price {
      font-family: 'Cormorant Garamond', serif;
      font-size: 2.25rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.1rem;
      line-height: 1;
    }
    .plan-cadence {
      font-family: 'JetBrains Mono', monospace;
      font-size: 0.62rem;
      color: var(--dim2);
      margin-bottom: 1.25rem;
    }
    .plan-features {
      list-style: none;
      padding: 0;
      margin: 0;
      font-size: 0.875rem;
      color: var(--dim);
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }
    .plan-features li.hi { color: var(--text); }

    /* Callout override for wraith */
    .callout-wraith {
      border-left: 3px solid var(--wraith);
      background: var(--wraith-glow);
      border-radius: 0 0.75rem 0.75rem 0;
      padding: 1.25rem 1.5rem;
      margin: 2rem 0;
      font-size: 0.9rem;
      color: var(--dim);
      line-height: 1.75;
    }
    .callout-wraith strong { color: var(--text); }
    .callout-wraith a { color: var(--wraith); }

    @media (min-width: 768px) {
      .app-hero { padding: 6rem 3.5rem 4.5rem; }
      .app-main { padding: 0 3.5rem 7rem; }
    }
    @media (min-width: 1100px) {
      .app-hero { padding: 7rem 5rem 5rem; }
      .app-main { padding: 0 5rem 8rem; }
    }
    @media (max-width: 480px) {
      .app-hero { padding: 3rem 1.25rem 2.5rem; }
      .app-main { padding: 0 1.25rem 4rem; }
    }
  </style>

  <script slot="head" type="application/ld+json">
    {
      "@context": "https://schema.org",
      "@type": "SoftwareApplication",
      "name": "WraithVPN",
      "operatingSystem": "iOS, macOS, Android",
      "applicationCategory": "SecurityApplication",
      "description": "WireGuard-based VPN with kill switch, multi-hop, and 10+ global exit nodes. Included with Enclave or Sovereign subscription.",
      "offers": {
        "@type": "Offer",
        "priceCurrency": "USD",
        "price": "8.00",
        "description": "Enclave subscription"
      },
      "author": {
        "@type": "Organization",
        "name": "Katafract LLC"
      }
    }
  </script>

  <div class="app-hero">
    <div class="app-hero-eyebrow">
      <span>Wraith</span>
      <span>&middot;</span>
      <span class="live-badge live-badge--soon"><span class="live-dot"></span>Coming Soon</span>
      <span>&middot;</span>
      <a href="/" class="back-link">by Katafract &nearr;</a>
    </div>
    <h1>Your traffic<br>is your <em>business</em>.<br>Full stop.</h1>
    <p class="tagline">Privacy-first VPN built on WireGuard. No logs. No tracking. No compromise. Global nodes across EU, US, and Asia. Haven DNS built in. Operated by people who refuse to be the product.</p>
    <div class="app-cta-row">
      <a href="https://apps.apple.com/app/id6745785827" class="btn-appstore plausible-event-name=AppStore+Click plausible-event-app=wraith">
        <svg viewBox="0 0 24 24" width="16" height="16" fill="currentColor"><path d="M18.71 19.5C17.88 20.74 17 21.95 15.66 21.97C14.32 21.99 13.89 21.18 12.37 21.18C10.84 21.18 10.37 21.95 9.09 21.99C7.79 22.03 6.8 20.68 5.96 19.47C4.25 16.97 2.94 12.45 4.7 9.39C5.57 7.87 7.13 6.91 8.82 6.88C10.1 6.86 11.32 7.75 12.11 7.75C12.89 7.75 14.37 6.68 15.92 6.84C16.57 6.87 18.39 7.1 19.56 8.82C19.47 8.88 17.39 10.1 17.41 12.63C17.44 15.65 20.06 16.66 20.09 16.67C20.06 16.74 19.67 18.11 18.71 19.5ZM13 3.5C13.73 2.67 14.94 2.04 15.94 2C16.07 3.17 15.6 4.35 14.9 5.19C14.21 6.04 13.07 6.7 11.95 6.61C11.8 5.46 12.36 4.26 13 3.5Z"/></svg>
        Download on the App Store
      </a>
      <a href="/support/wraith" class="btn--secondary">Learn More</a>
    </div>

  <main class="app-main">

    <hr class="section-divider">

    <div class="app-page-section">
      <div class="app-section-label">What Wraith Is</div>
      <h2 class="app-section-title">A VPN built for people who understand what&rsquo;s at stake</h2>
      <p class="app-section-sub">Most VPNs sell privacy as a feature while quietly building the infrastructure to compromise it. WraithVPN is different. It&rsquo;s built on open protocols, runs on infrastructure we control end-to-end, and has one policy: we don&rsquo;t keep records of you.</p>
    </div>

    <div class="features-grid" style="margin-top:2.5rem">
      <div class="feature-card">
        <div class="feature-icon">&#x26A1;</div>
        <div class="feature-title">WireGuard Protocol</div>
        <div class="feature-desc">Open-source. Audited. Lean. WireGuard&rsquo;s modern cryptography handshakes faster and leaks less than anything before it. No proprietary black boxes.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F6E1;&#xFE0F;</div>
        <div class="feature-title">Haven DNS</div>
        <div class="feature-desc">Every DNS query is a map of everything you&rsquo;ve looked at. Haven filters ads, blocks trackers, and never logs a single lookup. Included at every tier.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F512;</div>
        <div class="feature-title">Kill Switch</div>
        <div class="feature-desc">If the tunnel drops, so does your connection. Nothing leaks while reconnecting. Your real IP never surfaces. No exceptions.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F30D;</div>
        <div class="feature-title">Global Nodes</div>
        <div class="feature-desc">EU (Nuremberg, Helsinki), US (Portland, Ashburn, Newark), Asia (Singapore, Tokyo, Mumbai). Connect to the node nearest you or route through a specific region. Your call.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F300;</div>
        <div class="feature-title">Tunnel Modes</div>
        <div class="feature-desc">Standard mode routes only DNS through Wraith. Full mode routes all traffic. Switch instantly. Use Standard for speed, Full when it matters.</div>
      </div>
      <div class="feature-card">
        <div class="feature-icon">&#x1F9BE;</div>
        <div class="feature-title">Zero-Log Architecture</div>
        <div class="feature-desc">We don&rsquo;t log connection timestamps, assigned IPs, DNS queries, or session duration. There is nothing to subpoena. That&rsquo;s by design.</div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="app-page-section">
      <div class="app-section-label">Global Network</div>
      <h2 class="app-section-title">Global network. More coming.</h2>
      <p class="app-section-sub">All nodes run WireGuard and Haven DNS. The app auto-detects the best node for your location, or you choose manually.</p>
    </div>

    <div class="nodes-grid">
      <div class="node-card">
        <div class="node-region">US West</div>
        <div class="node-name">Portland</div>
        <div class="node-city">Oregon, US</div>
        <div class="node-status"><span class="node-dot"></span> Operational</div>
      </div>
      <div class="node-card">
        <div class="node-region">US East</div>
        <div class="node-name">Ashburn</div>
        <div class="node-city">Virginia, US</div>
        <div class="node-status"><span class="node-dot"></span> Operational</div>
      </div>
      <div class="node-card">
        <div class="node-region">US East</div>
        <div class="node-name">Newark</div>
        <div class="node-city">New Jersey, US</div>
        <div class="node-status"><span class="node-dot"></span> Operational</div>
      </div>
      <div class="node-card">
        <div class="node-region">EU West</div>
        <div class="node-name">Nuremberg</div>
        <div class="node-city">Bavaria, DE</div>
        <div class="node-status"><span class="node-dot"></span> Operational</div>
      </div>
      <div class="node-card">
        <div class="node-region">EU North</div>
        <div class="node-name">Helsinki</div>
        <div class="node-city">Finland</div>
        <div class="node-status"><span class="node-dot"></span> Operational</div>
      </div>
      <div class="node-card">
        <div class="node-region">AP Southeast</div>
        <div class="node-name">Singapore</div>
        <div class="node-city">Southeast Asia</div>
        <div class="node-status"><span class="node-dot"></span> Operational</div>
      </div>
      <div class="node-card">
        <div class="node-region">AP Northeast</div>
        <div class="node-name">Tokyo</div>
        <div class="node-city">Japan</div>
        <div class="node-status"><span class="node-dot"></span> Operational</div>
      </div>
      <div class="node-card">
        <div class="node-region">AP South</div>
        <div class="node-name">Mumbai</div>
        <div class="node-city">India</div>
        <div class="node-status"><span class="node-dot"></span> Operational</div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="app-page-section">
      <div class="app-section-label">How It Works</div>
      <h2 class="app-section-title">Private in three steps</h2>
    </div>

    <div class="steps">
      <div class="step">
        <div class="step-num">01</div>
        <div class="step-body">
          <h3>Sign In with Apple</h3>
          <p>Your identity stays with Apple. WraithVPN receives only an anonymized identifier &mdash; no email, no name, nothing you didn&rsquo;t choose to share. Sign in once, connect from any device.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">02</div>
        <div class="step-body">
          <h3>Choose Your Node</h3>
          <p>WraithVPN surfaces the closest, fastest node by default. Or tap any location in the list to route through a specific region. Nodes update automatically as new servers come online.</p>
        </div>
      </div>
      <div class="step">
        <div class="step-num">03</div>
        <div class="step-body">
          <h3>Connect. Disappear.</h3>
          <p>One tap. WireGuard handshake in milliseconds. Haven DNS filters immediately. Kill switch armed. From this point forward, what you browse is yours alone.</p>
        </div>
      </div>
    </div>

    <hr class="section-divider">

    <div class="manifesto">
      <div class="manifesto-label">Our commitment</div>
      <h2>We believe in the integrity of your data &mdash; and ours.</h2>
      <p>The VPN industry has a problem. Many providers market privacy while building revenue streams around the very data they claim to protect. Ad networks. Analytics pipelines. &ldquo;Anonymized&rdquo; usage statistics that aren&rsquo;t. We&rsquo;ve watched it happen and built WraithVPN in direct opposition to it.</p>
      <p>We don&rsquo;t track which sites you visit. We don&rsquo;t log when you connected or for how long. We don&rsquo;t store IP addresses assigned to sessions. We don&rsquo;t sell anonymized anything &mdash; because we don&rsquo;t collect it in the first place. When someone asks us to hand over user data, we genuinely have nothing to give them.</p>
      <p>This isn&rsquo;t a marketing position. It&rsquo;s an architectural one. The logs don&rsquo;t exist. The pipeline was never built. That choice was made before the first line of server code was written.</p>
      <div class="privacy-pills">
        <span class="privacy-pill">No connection logs</span>
        <span class="privacy-pill">No IP logging</span>
        <span class="privacy-pill">No DNS logging</span>
        <span class="privacy-pill">No analytics</span>
        <span class="privacy-pill">No third-party SDKs</span>
        <span class="privacy-pill">Open protocol (WireGuard)</span>
      </div>
    </div>

    <hr class="section-divider">

    <div class="app-page-section" style="margin-bottom:1.5rem">
      <div class="app-section-label">Plans</div>
      <h2 class="app-section-title">Privacy that scales with you</h2>
      <p class="app-section-sub">All plans include Haven DNS. VPN access starts at Enclave.</p>
    </div>

    <div class="pricing-grid">
      <div class="plan-card featured">
        <div class="plan-label">Enclave &nbsp;<span style="font-size:0.58rem;background:var(--wraith-dim);color:var(--wraith);padding:0.1rem 0.45rem;border-radius:999px;border:1px solid var(--wraith-border)">Popular</span></div>
        <a href="/pricing" style="display:inline-flex;align-items:center;gap:0.5rem;color:var(--wraith);font-weight:600;text-decoration:none;margin-top:0.5rem;transition:opacity 0.15s"><span>View pricing →</span></a>
        <ul class="plan-features">
          <li class="hi">&#x2713; WraithVPN with kill switch</li>
          <li class="hi">&#x2713; Haven DNS included</li>
          <li class="hi">&#x2713; Global exit nodes</li>
          <li class="hi">&#x2713; 5 devices</li>
          <li class="hi">&#x2713; All utility apps unlocked</li>
        </ul>
      </div>
      <div class="plan-card">
        <div class="plan-label">Sovereign</div>
        <a href="/pricing" style="display:inline-flex;align-items:center;gap:0.5rem;color:#818CF8;font-weight:600;text-decoration:none;margin-top:0.5rem;transition:opacity 0.15s"><span>View pricing →</span></a>
        <ul class="plan-features">
          <li class="hi">&#x2713; Everything in Enclave</li>
          <li class="hi">&#x2713; Multi-hop VPN routing</li>
          <li class="hi">&#x2713; 1TB Vaultyx storage</li>
          <li class="hi">&#x2713; Unlimited devices</li>
          <li class="hi">&#x2713; All future apps</li>
        </ul>
      </div>
    </div>

    <div class="callout-wraith">
      <strong>Stripe subscriber?</strong> If you purchased through our web portal, link your subscription in-app using the token provided at checkout. Tap Settings &rarr; Enter Access Token. <a href="/support/wraith">Full instructions &rarr;</a>
    </div>

    <hr class="section-divider">

    <div style="text-align:center;margin-bottom:1rem">
